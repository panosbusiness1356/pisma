---
/**
 * Ντοτ — η τελεία της PISMA που ζωντάνεψε.
 * Σύννεφο από πορτοκαλί κουκίδες με googly μάτια που ακολουθούν τον κέρσορα.
 * Ξεναγεί τον επισκέπτη: ταξιδεύει από section σε section (data-mascot-stop),
 * αλλάζει πλευρές και δείχνει συννεφάκι με το μήνυμα κάθε στάσης.
 * Οι κουκίδες παράγονται με seeded τυχαιότητα στο build — ίδιο σχήμα σε κάθε build.
 */
const palette = ['#FF7A45', '#FF9159', '#E8481F', '#FFB27A', '#FFD9A8'];
let seed = 7;
const rnd = () => {
  seed = (seed * 16807) % 2147483647;
  return seed / 2147483647;
};
type Dot = { x: number; y: number; r: number; c: string; o: number };
const dots: Dot[] = [];
for (let i = 0; i < 135; i++) {
  const a = rnd() * Math.PI * 2;
  const rr = 78 * Math.pow(rnd(), 0.55);
  dots.push({
    x: +(100 + Math.cos(a) * rr).toFixed(1),
    y: +(100 + Math.sin(a) * rr * 0.98).toFixed(1),
    r: +(rnd() < 0.12 ? 3.4 + rnd() * 1.8 : 1.2 + rnd() * 2.2).toFixed(1),
    c: palette[Math.floor(rnd() * palette.length)],
    o: +(0.45 + rnd() * 0.55).toFixed(2),
  });
}
const half = Math.ceil(dots.length / 2);
const cloudA = dots.slice(0, half);
const cloudB = dots.slice(half);
---

<div id="pisma-mascot" aria-hidden="true">
  <div class="m-bubble"><span class="m-bubble-text"></span></div>
  <div class="m-motion">
    <div class="m-bob">
      <svg viewBox="0 0 200 200" fill="none">
        <g class="d-spin">
          {cloudA.map((d) => <circle cx={d.x} cy={d.y} r={d.r} fill={d.c} opacity={d.o} />)}
        </g>
        <g class="d-spin2">
          {cloudB.map((d) => <circle cx={d.x} cy={d.y} r={d.r} fill={d.c} opacity={d.o} />)}
        </g>
        <g class="d-eyes">
          <circle cx="78" cy="95" r="18" fill="#FFF8F0" />
          <circle cx="120" cy="90" r="15" fill="#FFF8F0" />
          <g class="d-pup-l"><circle cx="78" cy="95" r="9" fill="#14101E" /></g>
          <g class="d-pup-r"><circle cx="120" cy="90" r="7.5" fill="#14101E" /></g>
        </g>
        <circle cx="101" cy="117" r="12.5" fill="#E8481F" />
      </svg>
    </div>
  </div>
</div>

<script>
  const el = document.getElementById('pisma-mascot')!;
  const motion = el.querySelector<HTMLElement>('.m-motion')!;
  const bubbleText = el.querySelector<HTMLElement>('.m-bubble-text')!;
  const pupL = el.querySelector<HTMLElement>('.d-pup-l')!;
  const pupR = el.querySelector<HTMLElement>('.d-pup-r')!;
  const stops = [...document.querySelectorAll<HTMLElement>('[data-mascot-stop]')];
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = () => window.matchMedia('(max-width: 680px)').matches;

  const W = () => (isMobile() ? 80 : 110);
  const H = () => W();

  /* Σημείο γέννησης: στην αρχική βγαίνει από την τελεία του logo· κάθε άλλη
     σελίδα τον γεννάει από δικό της, σχετικό σημείο (τιμή, chat, κουκίδα...).
     Αν το σημείο δεν είναι ορατό στο φόρτωμα, πέφτει στον τίτλο της σελίδας. */
  const SPAWNS: Array<[string, string]> = [
    ['/se-vriskoun', '.msg--user'],
    ['/doulevei-mono-tou', '.term-title'],
    ['/times', '.plan-setup'],
    ['/apodeixeis', '.after-num'],
    ['/tablo', '.dot'],
    ['/epikoinonia', '.c-value'],
    ['/timologisi-2026', '.count-num'],
    ['/elegxos', 'main h1'],
  ];
  const resolveSpawn = (): HTMLElement | null => {
    const path = location.pathname.replace(/\/$/, '') || '/';
    if (path === '/') return document.querySelector('.logo span');
    const visible = (e: HTMLElement | null) => {
      if (!e) return false;
      const r = e.getBoundingClientRect();
      return r.width > 0 && r.bottom > 90 && r.top < window.innerHeight - 60;
    };
    let el: HTMLElement | null = null;
    for (const [prefix, sel] of SPAWNS) {
      if (path.startsWith(prefix)) { el = document.querySelector(sel); break; }
    }
    if (!visible(el)) el = document.querySelector('main h1');
    if (!visible(el)) el = document.querySelector('.logo span');
    return el;
  };
  const spawnEl = resolveSpawn();
  let px = window.innerWidth - W() - 20;
  let py = window.innerHeight - H() - 24;
  let dotPos: { x: number; y: number } | null = null;
  if (spawnEl) {
    const r = spawnEl.getBoundingClientRect();
    dotPos = { x: r.left + r.width / 2 - W() / 2, y: r.top + r.height / 2 - H() / 2 };
    px = dotPos.x;
    py = dotPos.y;
  }
  const birth = { start: performance.now() + 600, dur: 900 };
  let scale = dotPos ? 0.08 : 1;
  let pulsed = false;

  /* Χορογραφία εισόδου: πετάει ως το «μόνο του» και ζωγραφίζει την υπογράμμιση
     σαν μαρκαδόρο, συγχρονισμένη με τη θέση του — μετά ξεκινά η ξενάγηση. */
  const hlSpan = document.querySelector<HTMLElement>('.hero-hl');
  const hlPath = document.querySelector<SVGPathElement>('.hl-stroke path');
  const hlLen = hlPath?.style.strokeDasharray ? parseFloat(hlPath.style.strokeDasharray) : 0;
  let phase: 'approach' | 'draw' | 'tour' = hlSpan && hlPath && hlLen > 0 && !reduce ? 'approach' : 'tour';
  const finishStroke = () => {
    if (hlPath) hlPath.style.strokeDashoffset = '0';
  };

  let rot = 0;
  let lastY = window.scrollY;
  let activeIdx = -2;
  let lastSide = 'right';
  let arrivedAt = 0;
  let bubbleOn = false;
  let greeted = false;
  let spokenIdx = -99;
  let mouseX = -1;
  let mouseY = -1;
  let eyeX = 0;
  let eyeY = 0;

  el.style.width = W() + 'px';

  /* Στις φαρδιές οθόνες κάθεται στο «λούκι» δίπλα στο περιεχόμενο· αλλιώς
     δεν χωράει δίπλα στο κείμενο, οπότε μένει χαμηλά στη γωνία της πλευράς του. */
  const gutter = () => (window.innerWidth - 1160) / 2 - W() - 8;
  const hasGutter = () => gutter() >= 14;
  const sideX = (side: string) => {
    const m = hasGutter() ? gutter() : 14;
    return side === 'left' ? m : window.innerWidth - W() - m;
  };

  const targetPos = () => {
    if (!stops.length) {
      return { x: window.innerWidth - W() - 20, y: window.innerHeight - H() - 24, idx: -1, side: 'right' };
    }
    const mid = window.innerHeight * 0.5;
    let idx = 0;
    let best = Infinity;
    stops.forEach((s, i) => {
      const r = s.getBoundingClientRect();
      const inView = r.top <= mid && r.bottom >= mid;
      const d = inView ? 0 : Math.min(Math.abs(r.top - mid), Math.abs(r.bottom - mid));
      if (d < best) { best = d; idx = i; }
    });
    const s = stops[idx];
    const r = s.getBoundingClientRect();
    const side = s.dataset.mascotSide || (idx % 2 ? 'left' : 'right');
    if (s.dataset.mascotPose === 'sit') {
      return { x: r.right - W() - r.width * 0.05, y: r.top - H() * 0.62, idx, side };
    }
    /* Στάση δίπλα σε συγκεκριμένο στοιχείο (π.χ. δίπλα στον τίτλο του hero). */
    const anchorSel = s.dataset.mascotAnchor;
    if (anchorSel) {
      const a = document.querySelector(anchorSel);
      if (a) {
        const ar = a.getBoundingClientRect();
        const x = side === 'left' ? ar.left - W() - 26 : ar.right + 26;
        const fits = x >= 8 && x + W() <= window.innerWidth - 8;
        if (fits) {
          const ay = Math.min(
            Math.max(ar.top + ar.height * 0.5 - H() * 0.5, 100),
            window.innerHeight - H() - 40
          );
          return { x, y: ay, idx, side };
        }
      }
    }
    const y = hasGutter()
      ? Math.min(Math.max(r.top + r.height * 0.3, 250), window.innerHeight - H() - 60)
      : window.innerHeight - H() - 28;
    return { x: sideX(side), y, idx, side };
  };

  let bubbleTimer: ReturnType<typeof setTimeout> | undefined;
  const showBubble = (msg: string | undefined, side: string) => {
    if (!msg) return;
    bubbleText.textContent = msg;
    el.classList.toggle('bubble-left', side === 'left');
    el.classList.add('has-bubble');
    bubbleOn = true;
    /* Κλείνει μόνο του για να μη μένει πάνω από κείμενα. */
    clearTimeout(bubbleTimer);
    bubbleTimer = setTimeout(hideBubble, 6500);
  };
  const hideBubble = () => {
    clearTimeout(bubbleTimer);
    el.classList.remove('has-bubble');
    bubbleOn = false;
  };

  const GREETING = 'Καλώς ήρθατε στην PISMA. Για μια γρήγορη εικόνα της επιχείρησής σας, δοκιμάστε το Ταμπλό — 2 λεπτά, χωρίς στοιχεία.';

  window.addEventListener('pointermove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
  }, { passive: true });

  if (reduce) {
    el.style.transform = `translate(${px}px, ${py}px)`;
    el.classList.add('is-ready');
  } else {
    const loop = () => {
      let t = targetPos();

      /* Φάσεις εισόδου: πάνω από το «μόνο του», τραβώντας τη γραμμή. */
      if (phase !== 'tour') {
        if (!hlSpan || window.scrollY > 80) {
          phase = 'tour';
          finishStroke();
        } else {
          const sr = hlSpan.getBoundingClientRect();
          const yLine = sr.bottom - H() * 0.35;
          if (phase === 'approach') {
            t = { x: sr.left - W() * 0.55, y: yLine, idx: -2, side: 'right' };
            if (Math.hypot(t.x - px, t.y - py) < 24) phase = 'draw';
          }
          if (phase === 'draw') {
            t = { x: sr.right - W() * 0.4, y: yLine, idx: -2, side: 'right' };
            const p = Math.min(1, Math.max(0, (px + W() / 2 - sr.left) / sr.width));
            hlPath!.style.strokeDashoffset = String(hlLen * (1 - p));
            if (p >= 0.97) {
              phase = 'tour';
              finishStroke();
            }
          }
        }
      }

      lastSide = t.side;
      if (t.idx !== activeIdx) {
        activeIdx = t.idx;
        arrivedAt = 0;
        if (bubbleOn) hideBubble();
      }

      /* Φάση γέννησης: καρφωμένος στην τελεία του logo, φουσκώνει με spring. */
      const now = performance.now();
      const birthing = dotPos && now < birth.start + birth.dur;
      if (birthing) {
        px = dotPos!.x;
        py = dotPos!.y;
        if (now >= birth.start) {
          if (!pulsed) {
            pulsed = true;
            try {
              /* Μικρά στοιχεία (τελεία) πάλλονται έντονα, μεγάλα πιο διακριτικά. */
              const sw = spawnEl!.getBoundingClientRect().width;
              const k = sw < 40 ? 2.2 : sw < 140 ? 1.35 : 1.12;
              if (getComputedStyle(spawnEl!).display === 'inline') spawnEl!.style.display = 'inline-block';
              spawnEl!.animate(
                [{ transform: 'scale(1)' }, { transform: `scale(${k})` }, { transform: 'scale(1)' }],
                { duration: 550, easing: 'ease-out' }
              );
            } catch { /* χωρίς παλμό */ }
          }
          const t01 = Math.min(1, (now - birth.start) / birth.dur);
          const c1 = 1.70158;
          const eased = 1 + (c1 + 1) * Math.pow(t01 - 1, 3) + c1 * Math.pow(t01 - 1, 2);
          scale = 0.08 + 0.92 * eased;
        }
      } else {
        scale = 1;
      }

      const dx = t.x - px;
      const dy = t.y - py;
      if (!birthing) {
        const k = phase === 'tour' ? 0.032 : 0.045;
        px += dx * k;
        py += dy * k;
      }
      const dist = Math.hypot(dx, dy);

      const y = window.scrollY;
      const vel = y - lastY;
      lastY = y;
      const lean = Math.max(-10, Math.min(10, dx * 0.028 + vel * 0.25));
      rot += (lean - rot) * 0.06;

      /* Τα μάτια κοιτούν τον κέρσορα — ή προς τα εκεί που ταξιδεύει. */
      const cx = px + W() / 2;
      const cy = py + H() / 2;
      let tx = 0;
      let ty = 0;
      if (mouseX >= 0) {
        tx = mouseX - cx;
        ty = mouseY - cy;
      } else if (dist > 24) {
        tx = dx;
        ty = dy;
      }
      const len = Math.hypot(tx, ty) || 1;
      const max = 7;
      const k = Math.min(1, len / 160);
      eyeX += ((tx / len) * max * k - eyeX) * 0.14;
      eyeY += ((ty / len) * max * k - eyeY) * 0.14;
      pupL.style.transform = `translate(${eyeX.toFixed(1)}px, ${eyeY.toFixed(1)}px)`;
      pupR.style.transform = `translate(${(eyeX * 0.85).toFixed(1)}px, ${(eyeY * 0.85).toFixed(1)}px)`;

      el.style.transform = `translate(${px.toFixed(1)}px, ${py.toFixed(1)}px)`;
      motion.style.transform = `rotate(${rot.toFixed(2)}deg) scale(${scale.toFixed(3)})`;

      if (dist < 40 && phase === 'tour') {
        if (!arrivedAt) arrivedAt = performance.now();
        else if (!bubbleOn && spokenIdx !== activeIdx && performance.now() - arrivedAt > 350) {
          spokenIdx = activeIdx;
          if (activeIdx >= 0) {
            showBubble(stops[activeIdx].dataset.mascotSay, t.side);
          } else if (!greeted) {
            greeted = true;
            showBubble(GREETING, 'right');
          }
        }
      } else if (dist > 130 && bubbleOn) {
        hideBubble();
      }

      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);
    requestAnimationFrame(() => el.classList.add('is-ready'));
  }

  window.addEventListener('resize', () => {
    el.style.width = W() + 'px';
  });

  /* Κλικ: χοροπηδηματάκι + ήχος + ξαναδείχνει το μήνυμα της στάσης. */
  el.addEventListener('pointerdown', () => {
    el.classList.remove('is-boing');
    void el.offsetWidth;
    el.classList.add('is-boing');
    const api = (window as unknown as { pismaSound?: { enabled: boolean; play: (n: string) => void } }).pismaSound;
    if (api?.enabled) api.play('click');
    if (!bubbleOn) {
      if (activeIdx >= 0) showBubble(stops[activeIdx].dataset.mascotSay, lastSide);
      else showBubble(GREETING, 'right');
    }
  });
</script>

<style>
  #pisma-mascot {
    position: fixed; left: 0; top: 0; z-index: 90;
    width: 110px; opacity: 0; cursor: pointer;
    will-change: transform;
    filter: drop-shadow(0 10px 26px rgba(238, 79, 39, .22));
    transition: opacity .7s ease;
  }
  #pisma-mascot.is-ready { opacity: 1; }
  #pisma-mascot svg { overflow: visible; width: 100%; height: auto; }

  /* Συννεφάκι ξενάγησης */
  .m-bubble {
    position: absolute; bottom: calc(100% + 12px); right: -8px;
    width: max-content; max-width: 250px;
    background: #221A33;
    border: 1px solid rgba(255, 122, 80, .5);
    border-radius: 14px;
    padding: 10px 14px;
    font-size: .85rem; line-height: 1.5; color: #F5F2FB;
    box-shadow: 0 14px 34px rgba(0, 0, 0, .45);
    opacity: 0; transform: translateY(8px) scale(.82);
    transform-origin: bottom right;
    transition: opacity .35s ease, transform .45s cubic-bezier(.34, 1.56, .64, 1);
    pointer-events: none;
  }
  .m-bubble::after {
    content: ''; position: absolute; bottom: -6px; right: 34px;
    width: 11px; height: 11px;
    background: #221A33;
    border-right: 1px solid rgba(255, 122, 80, .5);
    border-bottom: 1px solid rgba(255, 122, 80, .5);
    transform: rotate(45deg);
  }
  #pisma-mascot.bubble-left .m-bubble { right: auto; left: -8px; transform-origin: bottom left; }
  #pisma-mascot.bubble-left .m-bubble::after { right: auto; left: 34px; }
  #pisma-mascot.has-bubble .m-bubble { opacity: 1; transform: translateY(0) scale(1); }
  @media (max-width: 680px) {
    .m-bubble { max-width: 180px; font-size: .8rem; }
  }

  .m-motion { transform-origin: 50% 60%; }
  .m-bob { animation: m-bob 4.6s ease-in-out infinite alternate; }
  @keyframes m-bob {
    from { transform: translateY(0) scale(1); }
    to { transform: translateY(5px) scale(1.03); }
  }

  /* Το σύννεφο κουκίδων γυρίζει αργά — δύο στρώσεις, αντίθετες φορές. */
  .d-spin, .d-spin2 {
    transform-box: fill-box;
    transform-origin: center;
  }
  .d-spin { animation: d-spin 75s linear infinite; }
  .d-spin2 { animation: d-spin 110s linear infinite reverse; }
  @keyframes d-spin {
    to { transform: rotate(360deg); }
  }

  .d-eyes {
    transform-box: fill-box;
    transform-origin: center;
    animation: m-blink 5.4s infinite;
  }
  @keyframes m-blink {
    0%, 93.5%, 100% { transform: scaleY(1); }
    96.5% { transform: scaleY(.08); }
  }

  #pisma-mascot.is-boing svg { animation: m-boing .55s cubic-bezier(.34, 1.56, .64, 1); }
  @keyframes m-boing {
    30% { transform: scale(1.14, .88) translateY(3px); }
    60% { transform: scale(.94, 1.08) translateY(-4px); }
    100% { transform: scale(1) translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .m-bob, .d-spin, .d-spin2, .d-eyes { animation: none; }
  }
  @media print { #pisma-mascot { display: none; } }
</style>
