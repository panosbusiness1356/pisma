---
/**
 * Ντοτ — η τελεία της PISMA που ζωντάνεψε.
 * Σύννεφο από πορτοκαλί κουκίδες με googly μάτια που ακολουθούν τον κέρσορα.
 * Ξεναγεί τον επισκέπτη: ταξιδεύει από section σε section (data-mascot-stop),
 * αλλάζει πλευρές και δείχνει συννεφάκι με το μήνυμα κάθε στάσης.
 * Οι κουκίδες παράγονται με seeded τυχαιότητα στο build — ίδιο σχήμα σε κάθε build.
 */
const palette = ['#FF7A45', '#FF9159', '#E8481F', '#FFB27A', '#FFD9A8'];
let seed = 7;
const rnd = () => {
  seed = (seed * 16807) % 2147483647;
  return seed / 2147483647;
};
type Dot = { x: number; y: number; r: number; c: string; o: number };
const dots: Dot[] = [];
for (let i = 0; i < 135; i++) {
  const a = rnd() * Math.PI * 2;
  const rr = 78 * Math.pow(rnd(), 0.55);
  dots.push({
    x: +(100 + Math.cos(a) * rr).toFixed(1),
    y: +(100 + Math.sin(a) * rr * 0.98).toFixed(1),
    r: +(rnd() < 0.12 ? 3.4 + rnd() * 1.8 : 1.2 + rnd() * 2.2).toFixed(1),
    c: palette[Math.floor(rnd() * palette.length)],
    o: +(0.45 + rnd() * 0.55).toFixed(2),
  });
}
const half = Math.ceil(dots.length / 2);
const cloudA = dots.slice(0, half);
const cloudB = dots.slice(half);
---

<div id="pisma-mascot" aria-hidden="true">
  <div class="m-bubble"><span class="m-bubble-text"></span></div>
  <div class="m-motion">
    <div class="m-bob">
      <svg viewBox="0 0 200 200" fill="none">
        <g class="d-spin">
          {cloudA.map((d) => <circle cx={d.x} cy={d.y} r={d.r} fill={d.c} opacity={d.o} />)}
        </g>
        <g class="d-spin2">
          {cloudB.map((d) => <circle cx={d.x} cy={d.y} r={d.r} fill={d.c} opacity={d.o} />)}
        </g>
        <g class="d-eyes">
          <circle cx="78" cy="95" r="18" fill="#FFF8F0" />
          <circle cx="120" cy="90" r="15" fill="#FFF8F0" />
          <g class="d-pup-l"><circle cx="78" cy="95" r="9" fill="#14101E" /></g>
          <g class="d-pup-r"><circle cx="120" cy="90" r="7.5" fill="#14101E" /></g>
        </g>
        <circle cx="101" cy="117" r="12.5" fill="#E8481F" />
      </svg>
    </div>
  </div>
</div>

<script>
  const el = document.getElementById('pisma-mascot')!;
  const motion = el.querySelector<HTMLElement>('.m-motion')!;
  const bubbleText = el.querySelector<HTMLElement>('.m-bubble-text')!;
  const pupL = el.querySelector<HTMLElement>('.d-pup-l')!;
  const pupR = el.querySelector<HTMLElement>('.d-pup-r')!;
  const stops = [...document.querySelectorAll<HTMLElement>('[data-mascot-stop]')];
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = () => window.matchMedia('(max-width: 680px)').matches;

  const W = () => (isMobile() ? 80 : 110);
  const H = () => W();

  /* Γεννιέται μέσα από την πορτοκαλί τελεία του logo. */
  const logoDot = document.querySelector('.logo span');
  let px = window.innerWidth - W() - 20;
  let py = window.innerHeight - H() - 24;
  if (logoDot) {
    const r = logoDot.getBoundingClientRect();
    px = r.left + r.width / 2 - W() / 2;
    py = r.top + r.height / 2 - H() / 2;
  }

  let rot = 0;
  let lastY = window.scrollY;
  let activeIdx = -2;
  let lastSide = 'right';
  let arrivedAt = 0;
  let bubbleOn = false;
  let greeted = false;
  let mouseX = -1;
  let mouseY = -1;
  let eyeX = 0;
  let eyeY = 0;

  el.style.width = W() + 'px';

  /* Στις φαρδιές οθόνες κάθεται στο «λούκι» δίπλα στο περιεχόμενο· αλλιώς
     δεν χωράει δίπλα στο κείμενο, οπότε μένει χαμηλά στη γωνία της πλευράς του. */
  const gutter = () => (window.innerWidth - 1160) / 2 - W() - 8;
  const hasGutter = () => gutter() >= 14;
  const sideX = (side: string) => {
    const m = hasGutter() ? gutter() : 14;
    return side === 'left' ? m : window.innerWidth - W() - m;
  };

  const targetPos = () => {
    if (!stops.length) {
      return { x: window.innerWidth - W() - 20, y: window.innerHeight - H() - 24, idx: -1, side: 'right' };
    }
    const mid = window.innerHeight * 0.5;
    let idx = 0;
    let best = Infinity;
    stops.forEach((s, i) => {
      const r = s.getBoundingClientRect();
      const inView = r.top <= mid && r.bottom >= mid;
      const d = inView ? 0 : Math.min(Math.abs(r.top - mid), Math.abs(r.bottom - mid));
      if (d < best) { best = d; idx = i; }
    });
    const s = stops[idx];
    const r = s.getBoundingClientRect();
    const side = s.dataset.mascotSide || (idx % 2 ? 'left' : 'right');
    if (s.dataset.mascotPose === 'sit') {
      return { x: r.right - W() - r.width * 0.05, y: r.top - H() * 0.62, idx, side };
    }
    const y = hasGutter()
      ? Math.min(Math.max(r.top + r.height * 0.3, 250), window.innerHeight - H() - 60)
      : window.innerHeight - H() - 28;
    return { x: sideX(side), y, idx, side };
  };

  const showBubble = (msg: string | undefined, side: string) => {
    if (!msg) return;
    bubbleText.textContent = msg;
    el.classList.toggle('bubble-left', side === 'left');
    el.classList.add('has-bubble');
    bubbleOn = true;
  };
  const hideBubble = () => {
    el.classList.remove('has-bubble');
    bubbleOn = false;
  };

  const GREETING = 'Γεια! Είμαι ο Ντοτ — η τελεία της PISMA. Θες μια γρήγορη μέτρηση; Πάτα «Δωρεάν μέτρηση» πάνω δεξιά!';

  window.addEventListener('pointermove', (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
  }, { passive: true });

  if (reduce) {
    el.style.transform = `translate(${px}px, ${py}px)`;
    el.classList.add('is-ready');
  } else {
    const loop = () => {
      const t = targetPos();
      lastSide = t.side;
      if (t.idx !== activeIdx) {
        activeIdx = t.idx;
        arrivedAt = 0;
        if (bubbleOn) hideBubble();
      }

      const dx = t.x - px;
      const dy = t.y - py;
      px += dx * 0.075;
      py += dy * 0.075;
      const dist = Math.hypot(dx, dy);

      const y = window.scrollY;
      const vel = y - lastY;
      lastY = y;
      const lean = Math.max(-14, Math.min(14, dx * 0.045 + vel * 0.35));
      rot += (lean - rot) * 0.08;

      /* Τα μάτια κοιτούν τον κέρσορα — ή προς τα εκεί που ταξιδεύει. */
      const cx = px + W() / 2;
      const cy = py + H() / 2;
      let tx = 0;
      let ty = 0;
      if (mouseX >= 0) {
        tx = mouseX - cx;
        ty = mouseY - cy;
      } else if (dist > 24) {
        tx = dx;
        ty = dy;
      }
      const len = Math.hypot(tx, ty) || 1;
      const max = 7;
      const k = Math.min(1, len / 160);
      eyeX += ((tx / len) * max * k - eyeX) * 0.14;
      eyeY += ((ty / len) * max * k - eyeY) * 0.14;
      pupL.style.transform = `translate(${eyeX.toFixed(1)}px, ${eyeY.toFixed(1)}px)`;
      pupR.style.transform = `translate(${(eyeX * 0.85).toFixed(1)}px, ${(eyeY * 0.85).toFixed(1)}px)`;

      el.style.transform = `translate(${px.toFixed(1)}px, ${py.toFixed(1)}px)`;
      motion.style.transform = `rotate(${rot.toFixed(2)}deg)`;

      if (dist < 40) {
        if (!arrivedAt) arrivedAt = performance.now();
        else if (!bubbleOn && performance.now() - arrivedAt > 350) {
          if (activeIdx >= 0) {
            showBubble(stops[activeIdx].dataset.mascotSay, t.side);
          } else if (!greeted) {
            greeted = true;
            showBubble(GREETING, 'right');
            setTimeout(hideBubble, 8000);
          }
        }
      } else if (dist > 130 && bubbleOn) {
        hideBubble();
      }

      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);
    requestAnimationFrame(() => el.classList.add('is-ready'));
  }

  window.addEventListener('resize', () => {
    el.style.width = W() + 'px';
  });

  /* Κλικ: χοροπηδηματάκι + ήχος + ξαναδείχνει το μήνυμα της στάσης. */
  el.addEventListener('pointerdown', () => {
    el.classList.remove('is-boing');
    void el.offsetWidth;
    el.classList.add('is-boing');
    const api = (window as unknown as { pismaSound?: { enabled: boolean; play: (n: string) => void } }).pismaSound;
    if (api?.enabled) api.play('click');
    if (!bubbleOn) {
      if (activeIdx >= 0) showBubble(stops[activeIdx].dataset.mascotSay, lastSide);
      else showBubble(GREETING, 'right');
    }
  });
</script>

<style>
  #pisma-mascot {
    position: fixed; left: 0; top: 0; z-index: 90;
    width: 110px; opacity: 0; cursor: pointer;
    will-change: transform;
    filter: drop-shadow(0 10px 26px rgba(238, 79, 39, .22));
    transition: opacity .7s ease;
  }
  #pisma-mascot.is-ready { opacity: 1; }
  #pisma-mascot svg { overflow: visible; width: 100%; height: auto; }

  /* Συννεφάκι ξενάγησης */
  .m-bubble {
    position: absolute; bottom: calc(100% + 12px); right: -8px;
    width: max-content; max-width: 250px;
    background: #221A33;
    border: 1px solid rgba(255, 122, 80, .5);
    border-radius: 14px;
    padding: 10px 14px;
    font-size: .85rem; line-height: 1.5; color: #F5F2FB;
    box-shadow: 0 14px 34px rgba(0, 0, 0, .45);
    opacity: 0; transform: translateY(8px) scale(.82);
    transform-origin: bottom right;
    transition: opacity .35s ease, transform .45s cubic-bezier(.34, 1.56, .64, 1);
    pointer-events: none;
  }
  .m-bubble::after {
    content: ''; position: absolute; bottom: -6px; right: 34px;
    width: 11px; height: 11px;
    background: #221A33;
    border-right: 1px solid rgba(255, 122, 80, .5);
    border-bottom: 1px solid rgba(255, 122, 80, .5);
    transform: rotate(45deg);
  }
  #pisma-mascot.bubble-left .m-bubble { right: auto; left: -8px; transform-origin: bottom left; }
  #pisma-mascot.bubble-left .m-bubble::after { right: auto; left: 34px; }
  #pisma-mascot.has-bubble .m-bubble { opacity: 1; transform: translateY(0) scale(1); }
  @media (max-width: 680px) {
    .m-bubble { max-width: 180px; font-size: .8rem; }
  }

  .m-motion { transform-origin: 50% 60%; }
  .m-bob { animation: m-bob 4.6s ease-in-out infinite alternate; }
  @keyframes m-bob {
    from { transform: translateY(0) scale(1); }
    to { transform: translateY(5px) scale(1.03); }
  }

  /* Το σύννεφο κουκίδων γυρίζει αργά — δύο στρώσεις, αντίθετες φορές. */
  .d-spin, .d-spin2 {
    transform-box: fill-box;
    transform-origin: center;
  }
  .d-spin { animation: d-spin 75s linear infinite; }
  .d-spin2 { animation: d-spin 110s linear infinite reverse; }
  @keyframes d-spin {
    to { transform: rotate(360deg); }
  }

  .d-eyes {
    transform-box: fill-box;
    transform-origin: center;
    animation: m-blink 5.4s infinite;
  }
  @keyframes m-blink {
    0%, 93.5%, 100% { transform: scaleY(1); }
    96.5% { transform: scaleY(.08); }
  }

  #pisma-mascot.is-boing svg { animation: m-boing .55s cubic-bezier(.34, 1.56, .64, 1); }
  @keyframes m-boing {
    30% { transform: scale(1.14, .88) translateY(3px); }
    60% { transform: scale(.94, 1.08) translateY(-4px); }
    100% { transform: scale(1) translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .m-bob, .d-spin, .d-spin2, .d-eyes { animation: none; }
  }
  @media print { #pisma-mascot { display: none; } }
</style>
