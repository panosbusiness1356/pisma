---
/**
 * Οκτώ — το χταποδάκι-ξεναγός της PISMA.
 * Κολυμπάει από section σε section καθώς ο χρήστης σκρολάρει, αλλάζει πλευρές
 * (δεξιά/αριστερά) και δείχνει συννεφάκι με το σημαντικό μήνυμα κάθε ενότητας.
 * Τα σημεία-στάσεις ορίζονται με data-mascot-stop / data-mascot-say /
 * data-mascot-side / data-mascot-pose πάνω στα sections της σελίδας.
 * Σε σελίδες χωρίς στάσεις μένει στην κάτω-δεξιά γωνία με έναν χαιρετισμό.
 */
---

<div id="pisma-mascot" aria-hidden="true">
  <div class="m-bubble"><span class="m-bubble-text"></span></div>
  <div class="m-motion">
    <div class="m-bob">
      <svg viewBox="0 0 220 176" fill="none">
        <g class="m-tent" style="--dur:6.2s;--del:-1.3s;--amp:3.6deg">
          <path d="M65 115 C52 146 34 146 24 134" stroke="#FF7A45" stroke-width="11" stroke-linecap="round" />
          <rect x="8" y="118" width="18" height="24" rx="3" fill="#F5F2FB" />
          <path d="M12 125 h10 M12 131 h10 M12 137 h6" stroke="#A79DBB" stroke-width="2" stroke-linecap="round" />
        </g>
        <g class="m-tent" style="--dur:5.1s;--del:-2.6s;--amp:4.4deg">
          <path d="M88 123 C84 152 66 162 54 156" stroke="#FF7A45" stroke-width="11" stroke-linecap="round" />
        </g>
        <g class="m-tent" style="--dur:5.7s;--del:-.7s;--amp:3.2deg">
          <path d="M110 127 C112 152 98 164 88 162" stroke="#FF7A45" stroke-width="11" stroke-linecap="round" />
          <g transform="translate(62,151)">
            <rect width="24" height="17" rx="2.5" fill="#FFFFFF" />
            <path d="M2.5 4 L12 10.5 L21.5 4" stroke="#EA4335" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
            <rect x="1.2" y="2.5" width="3" height="12.5" rx="1.2" fill="#EA4335" />
            <rect x="19.8" y="2.5" width="3" height="12.5" rx="1.2" fill="#EA4335" />
          </g>
        </g>
        <g class="m-tent" style="--dur:4.8s;--del:-3.4s;--amp:4.6deg">
          <path d="M132 123 C136 152 154 162 166 156" stroke="#FF7A45" stroke-width="11" stroke-linecap="round" />
        </g>
        <g class="m-tent" style="--dur:6.6s;--del:-1.9s;--amp:3.8deg">
          <path d="M155 115 C168 144 186 144 198 134" stroke="#FF7A45" stroke-width="11" stroke-linecap="round" />
          <circle cx="202" cy="132" r="10" fill="#FFC24B" stroke="#C1841D" stroke-width="1.5" />
          <text x="202" y="136.5" text-anchor="middle" font-size="11" font-weight="700" fill="#7A5410" font-family="Commissioner, sans-serif">€</text>
        </g>
        <ellipse cx="110" cy="80" rx="52" ry="46" fill="#FF7A45" />
        <circle cx="80" cy="92" r="5" fill="#FFD9A8" opacity=".7" />
        <circle cx="140" cy="92" r="5" fill="#FFD9A8" opacity=".7" />
        <g class="m-eyes">
          <circle cx="93" cy="78" r="9" fill="#FFFFFF" />
          <circle cx="127" cy="78" r="9" fill="#FFFFFF" />
          <circle cx="95" cy="80" r="4.5" fill="#14101E" />
          <circle cx="125" cy="80" r="4.5" fill="#14101E" />
          <circle cx="97" cy="77" r="1.6" fill="#FFFFFF" />
          <circle cx="127" cy="77" r="1.6" fill="#FFFFFF" />
        </g>
        <path d="M99 98 Q110 105 121 98" stroke="#7A2408" stroke-width="3" stroke-linecap="round" />
      </svg>
    </div>
  </div>
</div>

<script>
  const el = document.getElementById('pisma-mascot')!;
  const motion = el.querySelector<HTMLElement>('.m-motion')!;
  const bubbleText = el.querySelector<HTMLElement>('.m-bubble-text')!;
  const stops = [...document.querySelectorAll<HTMLElement>('[data-mascot-stop]')];
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = () => window.matchMedia('(max-width: 680px)').matches;

  const W = () => (isMobile() ? 72 : 100);
  const H = () => W() * 0.8;

  let px = window.innerWidth - W() - 20;
  let py = window.innerHeight - H() - 24;
  let rot = 0;
  let lastY = window.scrollY;
  let activeIdx = -2;
  let lastSide = 'right';
  let arrivedAt = 0;
  let bubbleOn = false;
  let greeted = false;

  el.style.width = W() + 'px';

  /* Στις φαρδιές οθόνες κάθεται στο «λούκι» δίπλα στο περιεχόμενο· αλλιώς
     δεν χωράει δίπλα στο κείμενο, οπότε μένει χαμηλά στη γωνία της πλευράς του. */
  const gutter = () => (window.innerWidth - 1160) / 2 - W() - 8;
  const hasGutter = () => gutter() >= 14;
  const sideX = (side: string) => {
    const m = hasGutter() ? gutter() : 14;
    return side === 'left' ? m : window.innerWidth - W() - m;
  };

  const targetPos = () => {
    if (!stops.length) {
      return { x: window.innerWidth - W() - 20, y: window.innerHeight - H() - 24, idx: -1, side: 'right' };
    }
    const mid = window.innerHeight * 0.5;
    let idx = 0;
    let best = Infinity;
    stops.forEach((s, i) => {
      const r = s.getBoundingClientRect();
      const inView = r.top <= mid && r.bottom >= mid;
      const d = inView ? 0 : Math.min(Math.abs(r.top - mid), Math.abs(r.bottom - mid));
      if (d < best) { best = d; idx = i; }
    });
    const s = stops[idx];
    const r = s.getBoundingClientRect();
    const side = s.dataset.mascotSide || (idx % 2 ? 'left' : 'right');
    if (s.dataset.mascotPose === 'sit') {
      return { x: r.right - W() - r.width * 0.05, y: r.top - H() * 0.62, idx, side };
    }
    const y = hasGutter()
      ? Math.min(Math.max(r.top + r.height * 0.3, 250), window.innerHeight - H() - 60)
      : window.innerHeight - H() - 28;
    return { x: sideX(side), y, idx, side };
  };

  const showBubble = (msg: string | undefined, side: string) => {
    if (!msg) return;
    bubbleText.textContent = msg;
    el.classList.toggle('bubble-left', side === 'left');
    el.classList.add('has-bubble');
    bubbleOn = true;
  };
  const hideBubble = () => {
    el.classList.remove('has-bubble');
    bubbleOn = false;
  };

  const GREETING = 'Γεια! Είμαι ο Οκτώ. Θες μια γρήγορη μέτρηση; Πάτα «Δωρεάν μέτρηση» πάνω δεξιά!';

  if (reduce) {
    el.style.transform = `translate(${px}px, ${py}px)`;
    el.classList.add('is-ready');
  } else {
    const loop = () => {
      const t = targetPos();
      lastSide = t.side;
      if (t.idx !== activeIdx) {
        activeIdx = t.idx;
        arrivedAt = 0;
        if (bubbleOn) hideBubble();
      }

      const dx = t.x - px;
      const dy = t.y - py;
      px += dx * 0.075;
      py += dy * 0.075;
      const dist = Math.hypot(dx, dy);

      const y = window.scrollY;
      const vel = y - lastY;
      lastY = y;
      const lean = Math.max(-14, Math.min(14, dx * 0.045 + vel * 0.35));
      rot += (lean - rot) * 0.08;

      el.style.transform = `translate(${px.toFixed(1)}px, ${py.toFixed(1)}px)`;
      motion.style.transform = `rotate(${rot.toFixed(2)}deg)`;

      if (dist < 40) {
        if (!arrivedAt) arrivedAt = performance.now();
        else if (!bubbleOn && performance.now() - arrivedAt > 350) {
          if (activeIdx >= 0) {
            showBubble(stops[activeIdx].dataset.mascotSay, t.side);
          } else if (!greeted) {
            greeted = true;
            showBubble(GREETING, 'right');
            setTimeout(hideBubble, 8000);
          }
        }
      } else if (dist > 130 && bubbleOn) {
        hideBubble();
      }

      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);
    requestAnimationFrame(() => el.classList.add('is-ready'));
  }

  window.addEventListener('resize', () => {
    el.style.width = W() + 'px';
  });

  /* Κλικ: χοροπηδηματάκι + ήχος + ξαναδείχνει το μήνυμα της στάσης. */
  el.addEventListener('pointerdown', () => {
    el.classList.remove('is-boing');
    void el.offsetWidth;
    el.classList.add('is-boing');
    const api = (window as unknown as { pismaSound?: { enabled: boolean; play: (n: string) => void } }).pismaSound;
    if (api?.enabled) api.play('click');
    if (!bubbleOn) {
      if (activeIdx >= 0) showBubble(stops[activeIdx].dataset.mascotSay, lastSide);
      else showBubble(GREETING, 'right');
    }
  });
</script>

<style>
  #pisma-mascot {
    position: fixed; left: 0; top: 0; z-index: 90;
    width: 100px; opacity: 0; cursor: pointer;
    will-change: transform;
    filter: drop-shadow(0 12px 26px rgba(0, 0, 0, .4));
    transition: opacity .6s ease;
  }
  #pisma-mascot.is-ready { opacity: 1; }
  #pisma-mascot svg { overflow: visible; width: 100%; height: auto; }

  /* Συννεφάκι ξενάγησης */
  .m-bubble {
    position: absolute; bottom: calc(100% + 14px); right: -8px;
    width: max-content; max-width: 250px;
    background: #221A33;
    border: 1px solid rgba(255, 122, 80, .5);
    border-radius: 14px;
    padding: 10px 14px;
    font-size: .85rem; line-height: 1.5; color: #F5F2FB;
    box-shadow: 0 14px 34px rgba(0, 0, 0, .45);
    opacity: 0; transform: translateY(8px) scale(.82);
    transform-origin: bottom right;
    transition: opacity .35s ease, transform .45s cubic-bezier(.34, 1.56, .64, 1);
    pointer-events: none;
  }
  .m-bubble::after {
    content: ''; position: absolute; bottom: -6px; right: 34px;
    width: 11px; height: 11px;
    background: #221A33;
    border-right: 1px solid rgba(255, 122, 80, .5);
    border-bottom: 1px solid rgba(255, 122, 80, .5);
    transform: rotate(45deg);
  }
  #pisma-mascot.bubble-left .m-bubble { right: auto; left: -8px; transform-origin: bottom left; }
  #pisma-mascot.bubble-left .m-bubble::after { right: auto; left: 34px; }
  #pisma-mascot.has-bubble .m-bubble { opacity: 1; transform: translateY(0) scale(1); }
  @media (max-width: 680px) {
    .m-bubble { max-width: 180px; font-size: .8rem; }
  }

  .m-motion { transform-origin: 50% 60%; }
  .m-bob { animation: m-bob 4.6s ease-in-out infinite alternate; }
  @keyframes m-bob {
    from { transform: translateY(0); }
    to { transform: translateY(5px); }
  }

  .m-tent {
    transform-box: fill-box;
    transform-origin: 50% 6%;
    animation: m-sway var(--dur, 5s) ease-in-out var(--del, 0s) infinite alternate;
  }
  @keyframes m-sway {
    from { transform: rotate(var(--amp, 4deg)); }
    to { transform: rotate(calc(-1 * var(--amp, 4deg))); }
  }

  .m-eyes {
    transform-box: fill-box;
    transform-origin: center;
    animation: m-blink 5.4s infinite;
  }
  @keyframes m-blink {
    0%, 93.5%, 100% { transform: scaleY(1); }
    96.5% { transform: scaleY(.08); }
  }

  #pisma-mascot.is-boing svg { animation: m-boing .55s cubic-bezier(.34, 1.56, .64, 1); }
  @keyframes m-boing {
    30% { transform: scale(1.14, .88) translateY(3px); }
    60% { transform: scale(.94, 1.08) translateY(-4px); }
    100% { transform: scale(1) translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .m-bob, .m-tent, .m-eyes { animation: none; }
  }
  @media print { #pisma-mascot { display: none; } }
</style>
