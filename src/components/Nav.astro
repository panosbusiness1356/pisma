---
const links = [
  { href: '/se-vriskoun/', label: 'Ψηφιακή Προβολή' },
  { href: '/doulevei-mono-tou/', label: 'Αυτοματοποίηση' },
  { href: '/times/', label: 'Τιμές' },
  { href: '/apodeixeis/', label: 'Αποτελέσματα' },
];
// Κανονικοποίηση χωρίς trailing slash και στις δύο πλευρές της σύγκρισης.
const norm = (p: string) => p.replace(/\/$/, '') || '/';
const path = norm(Astro.url.pathname);
---

<header class="nav-wrap">
  <nav class="container nav" aria-label="Κύριο μενού">
    <a class="logo" href="/">PISMA<span>.</span></a>

    <ul class="nav-links" id="nav-links">
      {links.map((l) => (
        <li>
          <a href={l.href} aria-current={path === norm(l.href) ? 'page' : undefined}>{l.label}</a>
        </li>
      ))}
      <li class="nav-sound-mobile">
        <button type="button" data-sound-toggle aria-pressed="true">
          Ήχοι κλικ
          <span class="switch" aria-hidden="true"></span>
        </button>
      </li>
      <li class="nav-cta-mobile"><a class="btn btn--orange btn--sm" href="/tablo/">Μέτρησε την επιχείρησή σου</a></li>
      <li class="nav-cta-mobile nav-cta-mobile--second"><a class="btn btn--ghost btn--sm" href="/elegxos/">Δωρεάν αξιολόγηση 45′</a></li>
    </ul>

    <button class="sound-btn" type="button" data-sound-toggle aria-pressed="true" aria-label="Ήχοι κλικ" title="Ήχοι κλικ">
      <svg class="s-on" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M11 5 6 9H3v6h3l5 4z" fill="currentColor" stroke-width="2" />
        <path d="M15.5 8.5a5 5 0 0 1 0 7M18.5 6a9 9 0 0 1 0 12" stroke-width="2.6" />
      </svg>
      <svg class="s-off" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
        <path d="M11 5 6 9H3v6h3l5 4z" fill="currentColor" stroke-width="2" />
        <path d="m16 9 5 6M21 9l-5 6" stroke-width="2.6" />
      </svg>
    </button>

    <a class="btn btn--orange btn--sm nav-quiz" href="/tablo/">Μέτρησε την επιχείρησή σου</a>

    <button class="burger" type="button" aria-expanded="false" aria-controls="nav-links" aria-label="Μενού">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
        <path class="i-open" d="M4 7h16M4 12h16M4 17h16" />
        <path class="i-close" d="M6 6l12 12M18 6L6 18" style="display:none" />
      </svg>
    </button>
  </nav>
</header>

<script>
  const burger = document.querySelector<HTMLButtonElement>('.burger')!;
  const nav = document.getElementById('nav-links')!;
  burger.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    nav.classList.toggle('is-open', !open);
    (burger.querySelector('.i-open') as SVGElement).style.display = open ? '' : 'none';
    (burger.querySelector('.i-close') as SVGElement).style.display = open ? 'none' : '';
  });

  // Floating nav: μαζεύει σε «κάψουλα» με blur μετά από λίγο scroll.
  const wrap = document.querySelector<HTMLElement>('.nav-wrap')!;
  const onScroll = () => wrap.classList.toggle('is-scrolled', window.scrollY > 50);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Διακόπτες ήχων (εικονίδιο στο nav + σειρά στο mobile μενού) —
  // συγχρονίζονται όλοι μεταξύ τους μέσω του window.pismaSound (ορίζεται στο Base).
  const soundToggles = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-sound-toggle]'));
  const syncSound = (on: boolean) => {
    for (const btn of soundToggles) {
      btn.setAttribute('aria-pressed', String(on));
      const sOn = btn.querySelector<SVGElement>('.s-on');
      const sOff = btn.querySelector<SVGElement>('.s-off');
      if (sOn) sOn.style.display = on ? '' : 'none';
      if (sOff) sOff.style.display = on ? 'none' : '';
    }
  };
  try {
    syncSound(localStorage.getItem('pisma-sound') !== 'off');
  } catch { /* default: on */ }
  for (const btn of soundToggles) {
    btn.addEventListener('click', () => {
      const api = (window as unknown as { pismaSound?: { toggle: () => boolean } }).pismaSound;
      if (api) syncSound(api.toggle());
    });
  }
</script>

<style>
  .nav-wrap {
    position: sticky; top: 0; z-index: 100;
    padding: 8px 10px 0;
  }
  .nav {
    display: flex; align-items: center; gap: 20px; height: 64px;
    max-width: 1280px; /* φαρδύτερο από το default container για να χωρούν τα CTAs */
    border: 1px solid transparent; border-radius: 18px;
    transition: max-width .35s ease, background-color .35s ease, border-color .35s ease, box-shadow .35s ease;
  }
  .nav-wrap.is-scrolled .nav {
    max-width: 1060px;
    background: rgba(13, 10, 20, .72);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-color: var(--line-strong);
    box-shadow: var(--shadow);
  }
  .logo {
    font-family: var(--font-display); font-weight: 800; font-size: 1.25rem;
    color: var(--navy); text-decoration: none; letter-spacing: .01em; margin-right: auto;
    white-space: nowrap; flex: none;
  }
  .logo span { color: var(--orange); }
  .nav-links { display: flex; align-items: center; gap: 20px; list-style: none; padding: 0; flex-wrap: nowrap; }
  .nav-links a:not(.btn) {
    text-decoration: none; font-weight: 600; font-size: .95rem; color: var(--muted);
    padding: 6px 2px; border-radius: 6px;
    transition: color .15s ease;
    white-space: nowrap;
  }
  .nav-links a:not(.btn):hover { color: var(--navy); }
  .nav-links a[aria-current='page'] {
    color: var(--navy);
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 2px;
    text-decoration-color: var(--orange);
  }
  .nav-cta-mobile { display: none; }
  .nav-sound-mobile { display: none; }
  .sound-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; border-radius: 10px; flex: none;
    background: none; border: 0;
    color: var(--navy); cursor: pointer;
    transition: opacity .15s ease;
  }
  .sound-btn:hover { opacity: .8; }
  .sound-btn[aria-pressed='false'] { opacity: .65; }
  .sound-btn svg { flex: none; display: block; width: 26px; height: 26px; }
  .nav-quiz { flex: none; }
  .burger { display: none; background: none; border: 0; cursor: pointer; color: var(--navy); padding: 8px; border-radius: 10px; }
  .burger svg { width: 26px; height: 26px; }

  @media (max-width: 1080px) {
    .nav { gap: 14px; }
    .nav-quiz { display: none; }
    .burger { display: inline-flex; }
    .sound-btn { display: none; }
    .burger svg { width: 30px; height: 30px; }
    .nav-links {
      display: none;
      position: absolute; top: 76px; left: 0; right: 0;
      flex-direction: column; align-items: stretch; gap: 4px;
      background: var(--bg-soft); border-bottom: 1px solid var(--line);
      padding: 12px clamp(20px, 4vw, 36px) 20px;
      box-shadow: var(--shadow);
    }
    .nav-links.is-open { display: flex; }
    .nav-links a:not(.btn) { display: block; padding: 12px 4px; font-size: 1.05rem; }
    .nav-sound-mobile { display: block; border-top: 1px solid var(--line); margin-top: 6px; }
    .nav-sound-mobile button {
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      width: 100%; padding: 14px 4px; background: none; border: 0; cursor: pointer;
      font: inherit; font-weight: 600; font-size: 1.05rem; color: var(--navy); text-align: left;
    }
    .nav-sound-mobile .switch {
      position: relative; flex: none; width: 46px; height: 26px; border-radius: 13px;
      background: var(--card-2); border: 1px solid var(--line-strong);
      transition: background .2s ease, border-color .2s ease;
    }
    .nav-sound-mobile .switch::after {
      content: ''; position: absolute; top: 2px; left: 2px; width: 20px; height: 20px;
      border-radius: 50%; background: var(--muted);
      transition: transform .2s ease, background .2s ease;
    }
    .nav-sound-mobile button[aria-pressed='true'] .switch {
      background: var(--orange-soft); border-color: var(--orange);
    }
    .nav-sound-mobile button[aria-pressed='true'] .switch::after {
      transform: translateX(20px); background: var(--orange);
    }
    .nav-cta-mobile { display: block; margin-top: 10px; }
    .nav-cta-mobile--second { margin-top: 8px; }
    .nav-cta-mobile .btn { width: 100%; }
  }
</style>
