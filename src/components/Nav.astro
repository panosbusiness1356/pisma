---
const links = [
  { href: '/se-vriskoun/', label: 'Σε Βρίσκουν' },
  { href: '/doulevei-mono-tou/', label: 'Δουλεύει Μόνο Του' },
  { href: '/times/', label: 'Τιμές' },
  { href: '/apodeixeis/', label: 'Αποδείξεις' },
];
// Κανονικοποίηση χωρίς trailing slash και στις δύο πλευρές της σύγκρισης.
const norm = (p: string) => p.replace(/\/$/, '') || '/';
const path = norm(Astro.url.pathname);
---

<header class="nav-wrap">
  <nav class="container nav" aria-label="Κύριο μενού">
    <a class="logo" href="/">PISMA<span>.</span></a>

    <ul class="nav-links" id="nav-links">
      {links.map((l) => (
        <li>
          <a href={l.href} aria-current={path === norm(l.href) ? 'page' : undefined}>{l.label}</a>
        </li>
      ))}
      <li class="nav-cta-mobile"><a class="btn btn--orange btn--sm" href="/elegxos/">Δωρεάν αξιολόγηση</a></li>
    </ul>

    <button class="sound-btn" type="button" data-sound-toggle aria-pressed="true" aria-label="Ήχοι κλικ" title="Ήχοι κλικ">
      <svg class="s-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M11 5 6 9H3v6h3l5 4z" />
        <path d="M15.5 8.5a5 5 0 0 1 0 7M18.5 6a9 9 0 0 1 0 12" />
      </svg>
      <svg class="s-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none">
        <path d="M11 5 6 9H3v6h3l5 4z" />
        <path d="m16 9 5 6M21 9l-5 6" />
      </svg>
    </button>

    <a class="btn btn--orange btn--sm nav-cta" href="/elegxos/">Δωρεάν αξιολόγηση</a>

    <button class="burger" type="button" aria-expanded="false" aria-controls="nav-links" aria-label="Μενού">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
        <path class="i-open" d="M4 7h16M4 12h16M4 17h16" />
        <path class="i-close" d="M6 6l12 12M18 6L6 18" style="display:none" />
      </svg>
    </button>
  </nav>
</header>

<script>
  const burger = document.querySelector<HTMLButtonElement>('.burger')!;
  const nav = document.getElementById('nav-links')!;
  burger.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    nav.classList.toggle('is-open', !open);
    (burger.querySelector('.i-open') as SVGElement).style.display = open ? '' : 'none';
    (burger.querySelector('.i-close') as SVGElement).style.display = open ? 'none' : '';
  });

  // Floating nav: μαζεύει σε «κάψουλα» με blur μετά από λίγο scroll.
  const wrap = document.querySelector<HTMLElement>('.nav-wrap')!;
  const onScroll = () => wrap.classList.toggle('is-scrolled', window.scrollY > 50);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Διακόπτης ήχων — συγχρονίζεται με το window.pismaSound (ορίζεται στο Base).
  const soundBtn = document.querySelector<HTMLButtonElement>('[data-sound-toggle]')!;
  const syncSound = (on: boolean) => {
    soundBtn.setAttribute('aria-pressed', String(on));
    (soundBtn.querySelector('.s-on') as SVGElement).style.display = on ? '' : 'none';
    (soundBtn.querySelector('.s-off') as SVGElement).style.display = on ? 'none' : '';
  };
  try {
    syncSound(localStorage.getItem('pisma-sound') !== 'off');
  } catch { /* default: on */ }
  soundBtn.addEventListener('click', () => {
    const api = (window as unknown as { pismaSound?: { toggle: () => boolean } }).pismaSound;
    if (api) syncSound(api.toggle());
  });
</script>

<style>
  .nav-wrap {
    position: sticky; top: 0; z-index: 100;
    padding: 8px 10px 0;
  }
  .nav {
    display: flex; align-items: center; gap: 28px; height: 64px;
    border: 1px solid transparent; border-radius: 18px;
    transition: max-width .35s ease, background-color .35s ease, border-color .35s ease, box-shadow .35s ease;
  }
  .nav-wrap.is-scrolled .nav {
    max-width: 900px;
    background: rgba(13, 10, 20, .72);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-color: var(--line-strong);
    box-shadow: var(--shadow);
  }
  .logo {
    font-family: var(--font-display); font-weight: 800; font-size: 1.25rem;
    color: var(--navy); text-decoration: none; letter-spacing: .01em; margin-right: auto;
    white-space: nowrap; flex: none;
  }
  .logo span { color: var(--orange); }
  .nav-links { display: flex; align-items: center; gap: 26px; list-style: none; padding: 0; }
  .nav-links a:not(.btn) {
    text-decoration: none; font-weight: 600; font-size: .95rem; color: var(--muted);
    padding: 6px 2px; border-radius: 6px;
    transition: color .15s ease;
  }
  .nav-links a:not(.btn):hover { color: var(--navy); }
  .nav-links a[aria-current='page'] {
    color: var(--navy);
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 2px;
    text-decoration-color: var(--orange);
  }
  .nav-cta-mobile { display: none; }
  .sound-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 38px; height: 38px; border-radius: 50%; flex: none;
    background: transparent; border: 1px solid var(--line-strong);
    color: var(--muted); cursor: pointer;
    transition: color .15s ease, border-color .15s ease;
  }
  .sound-btn:hover { color: var(--navy); border-color: rgba(255, 255, 255, .35); }
  .sound-btn[aria-pressed='false'] { opacity: .65; }
  .sound-btn svg { width: 18px; height: 18px; }
  .burger { display: none; background: none; border: 0; cursor: pointer; color: var(--navy); padding: 8px; border-radius: 10px; }
  .burger svg { width: 26px; height: 26px; }

  @media (max-width: 880px) {
    .nav { gap: 14px; }
    .nav-cta { display: none; }
    .burger { display: inline-flex; }
    .nav-links {
      display: none;
      position: absolute; top: 76px; left: 0; right: 0;
      flex-direction: column; align-items: stretch; gap: 4px;
      background: var(--bg-soft); border-bottom: 1px solid var(--line);
      padding: 12px clamp(20px, 4vw, 36px) 20px;
      box-shadow: var(--shadow);
    }
    .nav-links.is-open { display: flex; }
    .nav-links a:not(.btn) { display: block; padding: 12px 4px; font-size: 1.05rem; }
    .nav-cta-mobile { display: block; margin-top: 10px; }
    .nav-cta-mobile .btn { width: 100%; }
  }
</style>
