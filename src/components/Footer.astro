---
import { SITE } from '../config';

const solutions = [
  { href: '/se-vriskoun/', label: 'Ψηφιακή Προβολή' },
  { href: '/doulevei-mono-tou/', label: 'Αυτοματοποίηση' },
];
const tools = [
  { href: '/tablo/', label: 'Το Ταμπλό' },
  { href: '/elegxos/', label: 'Ο Έλεγχος PISMA' },
  { href: '/apodeixeis/', label: 'Αποτελέσματα' },
];
const company = [
  { href: '/times/', label: 'Τιμές' },
  { href: '/epikoinonia/', label: 'Επικοινωνία' },
];
---

<footer class="footer">
  <div class="container cols">
    <div class="brand">
      <p class="logo">PISMA<span>.</span></p>
      <p class="tagline">{SITE.tagline}</p>
      <a class="btn btn--orange btn--sm cta" href="/elegxos/">Κλείστε δωρεάν αξιολόγηση</a>
    </div>

    <nav aria-label="Λύσεις">
      <h2 class="col-title">Λύσεις</h2>
      <ul>
        {solutions.map((p) => (
          <li><a href={p.href}>{p.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav aria-label="Εργαλεία">
      <h2 class="col-title">Εργαλεία</h2>
      <ul>
        {tools.map((p) => (
          <li><a href={p.href}>{p.label}</a></li>
        ))}
      </ul>
    </nav>

    <div>
      <h2 class="col-title">Επικοινωνία</h2>
      <ul>
        {company.map((p) => (
          <li><a href={p.href}>{p.label}</a></li>
        ))}
        <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        <li><a href={`tel:${SITE.phone.replace(/\s/g, '')}`}>{SITE.phone}</a></li>
      </ul>
    </div>
  </div>
  <div class="container bottom">
    <p>© {new Date().getFullYear()} PISMA</p>
    <p class="bottom-note">Με πείσμα, μέχρι να δουλεύει μόνο του.</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    background:
      radial-gradient(70% 90% at 50% 120%, rgba(139, 92, 246, .10), transparent 70%),
      var(--bg-soft);
    margin-top: clamp(40px, 7vw, 80px);
  }
  .cols {
    display: grid; gap: 36px;
    grid-template-columns: repeat(auto-fit, minmax(min(220px, 100%), 1fr));
    padding-block: clamp(40px, 6vw, 64px) 28px;
  }
  .brand { max-width: 300px; }
  .logo { font-family: var(--font-display); font-weight: 800; font-size: 1.3rem; color: var(--navy); }
  .logo span { color: var(--orange); }
  .tagline { margin-top: 10px; font-size: .95rem; color: var(--muted); font-style: italic; }
  .who { margin-top: 14px; font-size: .92rem; font-weight: 600; color: var(--navy); }
  .col-title { font-family: var(--font-body); font-size: .8rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; }
  ul { list-style: none; padding: 0; display: grid; gap: 9px; }
  ul a { text-decoration: none; font-size: .95rem; color: var(--ink); }
  ul a:hover { color: var(--orange-text); }
  .cta { margin-top: 20px; }
  .bottom {
    border-top: 1px solid var(--line); padding-block: 18px;
    font-size: .85rem; color: var(--muted);
    display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap;
  }

  @media (max-width: 680px) {
    .cols { grid-template-columns: 1fr 1fr; gap: 24px 18px; padding-block: 34px 20px; }
    .brand { grid-column: 1 / -1; max-width: none; }
    .footer { margin-top: 36px; }
  }
</style>
