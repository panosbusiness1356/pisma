---
import { EINVOICE } from '../config';
---

<div class="ribbon" id="deadline-ribbon">
  <a href="/timologisi-2026/">
    <strong>{EINVOICE.deadlineShort}</strong> — Υποχρεωτική ηλεκτρονική τιμολόγηση για όλες τις επιχειρήσεις. Είστε έτοιμοι; →
  </a>
  <button type="button" aria-label="Κλείσιμο ειδοποίησης" data-dismiss>&times;</button>
</div>

<script is:inline>
  // Συγχρονισμένα πριν το paint, για να μην τρεμοπαίζει η κορδέλα.
  (function () {
    function safeGet(k) { try { return localStorage.getItem(k); } catch (e) { return null; } }
    function safeSet(k, v) { try { localStorage.setItem(k, v); } catch (e) { /* no persistence */ } }
    var r = document.getElementById('deadline-ribbon');
    if (safeGet('pisma-ribbon-dismissed') === '1') { r.remove(); return; }
    r.querySelector('[data-dismiss]').addEventListener('click', function () {
      safeSet('pisma-ribbon-dismissed', '1');
      r.remove();
    });
  })();
</script>

<style>
  .ribbon {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    background: var(--red-deep); color: #fff;
    font-size: .88rem; font-weight: 600;
    padding: 8px clamp(14px, 3vw, 24px);
    text-align: center;
  }
  .ribbon a { color: #fff; text-decoration: none; }
  .ribbon a:hover { text-decoration: underline; }
  .ribbon button {
    background: none; border: 0; color: #fff; cursor: pointer;
    font-size: 1.25rem; line-height: 1; padding: 2px 8px; border-radius: 6px; flex: none;
  }
  .ribbon button:hover { background: rgba(255, 255, 255, .18); }
</style>
