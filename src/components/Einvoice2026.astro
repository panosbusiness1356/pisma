---
/**
 * Πάνελ «Ηλεκτρονική τιμολόγηση 2026» — ΠΡΟΣΩΡΙΝΑ ΕΚΤΟΣ αρχικής (15/07/2026,
 * απόφαση χρήστη: «κράτησέ το, βγάλε το από το site για τώρα»).
 * Επαναφορά: import Einvoice2026 from '../components/Einvoice2026.astro';
 * και <Einvoice2026 /> ανάμεσα στη Μεθοδολογία και τα Αποτελέσματα του index.
 * Τα στυλ .einv* παραμένουν στο <style> του index.astro.
 */
import { EINVOICE, eur } from '../config';
---

<section
  class="section section--tight"
  aria-labelledby="einv-title"
  data-mascot-stop
  data-mascot-side="left"
  data-mascot-say={`Προθεσμία ${EINVOICE.deadlineShort}: η ηλεκτρονική τιμολόγηση γίνεται υποχρεωτική. Η μετάβαση απαιτεί ${EINVOICE.migrationWeeks}.`}
>
  <div class="container">
    <div class="einv reveal">
      <div class="einv-copy">
        <h2 id="einv-title">Ηλεκτρονική τιμολόγηση 2026</h2>
        <p>
          Από την {EINVOICE.deadlineHuman}, η ηλεκτρονική τιμολόγηση καθίσταται υποχρεωτική
          για όλες τις επιχειρήσεις. Αναλαμβάνουμε τον πλήρη κύκλο προσαρμογής, ώστε να
          είστε συμβατοί πριν από την προθεσμία.
        </p>
        <ul class="einv-checks">
          <li><span aria-hidden="true">✓</span> Προθεσμία: {EINVOICE.deadlineHuman}, για όλες τις επιχειρήσεις</li>
          <li><span aria-hidden="true">✓</span> Πρόστιμα έως {eur(EINVOICE.maxFine)} ανά παράβαση</li>
          <li><span aria-hidden="true">✓</span> Απαιτούμενος χρόνος μετάβασης: {EINVOICE.migrationWeeks}</li>
        </ul>
        <a class="btn btn--light" href="/timologisi-2026/">Ενημερωθείτε αναλυτικά</a>
      </div>
      <div class="einv-panel" aria-hidden="true">
        <div class="einv-node">Τιμολόγιο</div>
        <div class="einv-arrow">→</div>
        <div class="einv-node einv-node--ok">myDATA ✓</div>
      </div>
    </div>
  </div>
</section>
