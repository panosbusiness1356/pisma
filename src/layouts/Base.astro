---
import '../styles/global.css';
import Ribbon from '../components/Ribbon.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Mascot from '../components/Mascot.astro';
import { SITE } from '../config';

interface Props {
  title: string;
  description: string;
  /** JSON-LD αντικείμενο ή πίνακας αντικειμένων (schema.org) */
  schema?: object | object[];
  /** Προαιρετική εικόνα κοινοποίησης (π.χ. campaign visual) — default το /og.png */
  image?: string;
}

const { title, description, schema, image = '/og.png' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? SITE.url).href;
const ogImage = new URL(image, Astro.site ?? SITE.url).href;
const schemas = schema ? (Array.isArray(schema) ? schema : [schema]) : [];
---

<!doctype html>
<html lang="el">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0D0A14" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content="el_GR" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${SITE.name} — ${SITE.tagline}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Unbounded:wght@600;800&family=Commissioner:wght@400;600;700&family=JetBrains+Mono:wght@500;700&display=swap"
    />

    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  </head>
  <body>
    <a class="skip-link" href="#main">Μετάβαση στο περιεχόμενο</a>
    <Ribbon />
    <Nav />
    <main id="main" class="page-in">
      <slot />
    </main>
    <Footer />
    <Mascot />

    <script>
      // Smooth scroll με αδράνεια (Lenis) — ίδιο σύστημα με τα σύγχρονα studio sites.
      // Σεβασμός στο prefers-reduced-motion: εκεί μένει το native scroll.
      import Lenis from 'lenis';

      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const lenis = new Lenis({
          duration: 1.15,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          smoothWheel: true,
          wheelMultiplier: 1,
          touchMultiplier: 1.4,
          anchors: true,
        });
        const raf = (time: number) => {
          lenis.raf(time);
          requestAnimationFrame(raf);
        };
        requestAnimationFrame(raf);
      }
    </script>

    <script>
      // Ηχητικά εφέ UI — συντίθενται live με Web Audio (χωρίς αρχεία ήχου).
      // Δημόσιο API: window.pismaSound.{enabled, toggle(), play(name)}
      // + event 'pisma-sound-change' για συγχρονισμό του διακόπτη στο μενού.
      type SoundName = 'click' | 'tick' | 'on' | 'off';

      const store = {
        get enabled() {
          try { return localStorage.getItem('pisma-sound') !== 'off'; } catch { return true; }
        },
        set enabled(v: boolean) {
          try { localStorage.setItem('pisma-sound', v ? 'on' : 'off'); } catch { /* χωρίς αποθήκευση */ }
        },
      };

      let ctx: AudioContext | undefined;
      let master: GainNode | undefined;
      let noiseBuf: AudioBuffer | undefined;
      const audio = () => {
        ctx ||= new AudioContext();
        if (!master) {
          master = ctx.createGain();
          master.gain.value = 0.9;
          master.connect(ctx.destination);
        }
        if (ctx.state === 'suspended') ctx.resume();
        return ctx;
      };

      /** Καθαρός τόνος με πτώση/άνοδο συχνότητας και εκθετικό σβήσιμο. */
      const tone = (o: { type?: OscillatorType; from: number; to?: number; delay?: number; dur: number; peak: number }) => {
        const c = audio();
        const t = c.currentTime + (o.delay ?? 0);
        const osc = c.createOscillator();
        const g = c.createGain();
        osc.type = o.type ?? 'sine';
        osc.frequency.setValueAtTime(o.from, t);
        if (o.to) osc.frequency.exponentialRampToValueAtTime(o.to, t + o.dur);
        g.gain.setValueAtTime(o.peak, t);
        g.gain.exponentialRampToValueAtTime(0.0001, t + o.dur);
        osc.connect(g).connect(master!);
        osc.start(t);
        osc.stop(t + o.dur + 0.02);
      };

      /** Σύντομη «πνοή» θορύβου για το φυσικό αίσθημα του tap. */
      const puff = (o: { delay?: number; dur: number; peak: number; cutoff: number }) => {
        const c = audio();
        if (!noiseBuf) {
          noiseBuf = c.createBuffer(1, Math.floor(c.sampleRate * 0.1), c.sampleRate);
          const d = noiseBuf.getChannelData(0);
          for (let i = 0; i < d.length; i++) d[i] = Math.random() * 2 - 1;
        }
        const t = c.currentTime + (o.delay ?? 0);
        const src = c.createBufferSource();
        src.buffer = noiseBuf;
        const f = c.createBiquadFilter();
        f.type = 'highpass';
        f.frequency.value = o.cutoff;
        const g = c.createGain();
        g.gain.setValueAtTime(o.peak, t);
        g.gain.exponentialRampToValueAtTime(0.0001, t + o.dur);
        src.connect(f).connect(g).connect(master!);
        src.start(t);
        src.stop(t + o.dur + 0.02);
      };

      const sounds: Record<SoundName, () => void> = {
        // Κουμπιά/CTA: ζεστό, γεμάτο «ποπ»
        click() {
          tone({ from: 440, to: 170, dur: 0.09, peak: 0.1 });
          tone({ type: 'triangle', from: 920, to: 540, dur: 0.07, peak: 0.03 });
          puff({ dur: 0.03, peak: 0.045, cutoff: 2600 });
        },
        // Links/tabs/πεδία: ελαφρύ «τικ»
        tick() {
          tone({ from: 980, to: 620, dur: 0.05, peak: 0.05 });
          puff({ dur: 0.02, peak: 0.02, cutoff: 4200 });
        },
        // Ενεργοποίηση ήχων: ανοδικό κουδουνάκι (Ντο→Σολ)
        on() {
          tone({ from: 523.25, dur: 0.18, peak: 0.06 });
          tone({ from: 783.99, delay: 0.09, dur: 0.22, peak: 0.05 });
          tone({ type: 'triangle', from: 1046.5, delay: 0.09, dur: 0.2, peak: 0.015 });
        },
        // Απενεργοποίηση: χαμηλό, σβηστό «ντουπ»
        off() {
          tone({ from: 340, to: 150, dur: 0.12, peak: 0.06 });
        },
      };

      const play = (name: SoundName) => {
        try { sounds[name](); } catch { /* χωρίς ήχο αν το μπλοκάρει ο browser */ }
      };

      (window as any).pismaSound = {
        get enabled() { return store.enabled; },
        toggle() {
          const next = !store.enabled;
          if (next) { store.enabled = true; play('on'); }
          else { play('off'); store.enabled = false; }
          document.dispatchEvent(new CustomEvent('pisma-sound-change', { detail: { enabled: next } }));
          return next;
        },
        play,
      };

      document.addEventListener(
        'pointerdown',
        (e) => {
          if (!store.enabled) return;
          const el = e.target as Element | null;
          if (!el || el.closest('[data-sound-toggle]')) return; // ο διακόπτης έχει δικούς του ήχους
          if (el.closest('.btn')) play('click');
          else if (el.closest('a, button, [role="tab"], label, select, input, summary')) play('tick');
        },
        { capture: true, passive: true }
      );
    </script>

    <script>
      // Reveal on scroll — σεβασμός στο prefers-reduced-motion.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const els = document.querySelectorAll('.reveal');
      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-in'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-in');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      }
    </script>

    <style>
      .page-in { animation: pageIn .5s ease both; }
      @keyframes pageIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: none; }
      }
      @media (prefers-reduced-motion: reduce) {
        .page-in { animation: none; }
      }
    </style>
  </body>
</html>
