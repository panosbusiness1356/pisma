---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import { SITE, ELEGXOS } from '../config';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Αποδείξεις — Νούμερα πριν και μετά',
  description:
    'Ενδεικτικά σενάρια εφαρμογής με μετρήσιμο πριν και μετά, και τα ζωντανά συστήματα της PISMA.',
  url: `${SITE.url}/apodeixeis/`,
  inLanguage: 'el',
  isPartOf: { '@type': 'WebSite', name: SITE.name, url: SITE.url },
};

/** Ενδεικτικά σενάρια — δηλώνονται καθαρά ως σενάρια, όχι ως πελάτες. */
const demoCases = [
  {
    title: 'Εμπορική εταιρεία — περίπου 400 παραστατικά τον μήνα',
    metric: 'Καταχώρηση εισερχομένων',
    before: '22 ώρες/μήνα',
    after: '3',
    setup:
      'Στήθηκε αυτόματη ανάγνωση παραστατικών από το email και καταχώρηση στο σύστημα — ο άνθρωπος μόνο εγκρίνει.',
    icon: 'doc',
  },
  {
    title: 'Τεχνική εταιρεία — έργα με πίστωση',
    metric: 'Μέση είσπραξη',
    before: '47 μέρες',
    after: '31',
    setup:
      'Στήθηκαν αυτόματες υπενθυμίσεις είσπραξης σε 3 βήματα — ευγενικές στην αρχή, σταθερές μετά.',
    icon: 'clock',
  },
] as const;
---

<Base
  title="Αποδείξεις: νούμερα πριν και μετά, μετρημένα | PISMA"
  description="Πριν και μετά σε ώρες και μέρες: ενδεικτικά σενάρια εφαρμογής και τα ζωντανά συστήματα της PISMA — με δέσμευση για επώνυμες, ποτέ ανώνυμες μαρτυρίες."
  schema={schema}
>
  <PageHero
    kicker="Αποδείξεις"
    sub="Κάθε έργο μετριέται πριν και μετά. Ό,τι δεν μετριέται, δεν το πουλάμε."
  >
    Νούμερα, <span class="accent">όχι λόγια</span>.
  </PageHero>

  <!-- Πριν → Μετά -->
  <section class="section section--tight" aria-labelledby="cases-title">
    <div class="container">
      <div class="sec-head">
        <p class="kicker">Πριν → Μετά</p>
        <h2 id="cases-title">Πριν και μετά, δίπλα-δίπλα.</h2>
        <p>
          Τα δύο πρώτα είναι σενάρια εφαρμογής με ρεαλιστικά μεγέθη — όχι πελάτες. Γι' αυτό και το
          γράφουμε πάνω τους.
        </p>
      </div>

      <div class="grid-3">
        {demoCases.map((c) => (
          <article class="card case reveal">
            <div class="case-top">
              <span class="icon-chip">
                {c.icon === 'doc' ? (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" />
                    <path d="M14 3v5h5" />
                    <path d="M9 13h6M9 17h4" />
                  </svg>
                ) : (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="12" cy="12" r="8.5" />
                    <path d="M12 7.5V12l3 2" />
                  </svg>
                )}
              </span>
              <span class="tag tag--demo">Ενδεικτικό σενάριο εφαρμογής</span>
            </div>
            <h3>{c.title}</h3>
            <p class="case-metric-label">{c.metric}</p>
            <p class="case-nums">
              <span class="strike num">{c.before}</span>
              <span class="case-arrow" aria-hidden="true">→</span>
              <span class="visually-hidden">έγινε</span>
              <span class="after-num">{c.after}</span>
            </p>
            <p class="case-setup">{c.setup}</p>
          </article>
        ))}

        <article class="card case case--live reveal">
          <div class="case-top">
            <span class="icon-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 12h4l2.5-6 5 12 2.5-6h4" />
              </svg>
            </span>
            <span class="tag tag--live">Ζωντανό</span>
          </div>
          <h3>PISMA — τα δικά μας συστήματα</h3>
          <p>
            Υποδοχή αιτημάτων, προτάσεις, follow-ups και τιμολόγηση τρέχουν με ό,τι ακριβώς
            πουλάμε. Δεν πουλάμε κάτι που δεν χρησιμοποιούμε.
          </p>
          <a class="card-arrow" href="/elegxos/">Ζήτα να τα δεις live στο ραντεβού →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- Placeholder μελλοντικών μαρτυριών -->
  <section class="section" aria-labelledby="testimonials-title">
    <div class="container">
      <div class="sec-head">
        <p class="kicker">Μαρτυρίες</p>
        <h2 id="testimonials-title">Εδώ θα μπουν τα δικά σου νούμερα</h2>
        <p>Η σελίδα είναι καινούργια — και δεν τη στολίζουμε με δανεικά.</p>
      </div>
      <div class="promise reveal">
        <span class="icon-chip">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M17 3.5 20.5 7 8 19.5 4 20l.5-4z" />
          </svg>
        </span>
        <h3>Κάθε μαρτυρία, επώνυμη.</h3>
        <p>
          Όταν μπει εδώ η πρώτη, θα έχει όνομα, επιχείρηση και περιοχή — ποτέ «ικανοποιημένος
          πελάτης, Αθήνα».
        </p>
      </div>
    </div>
  </section>

  <CtaBand
    title="Θες τέτοια νούμερα; Ξεκινάμε με μέτρηση."
    sub="Ο Έλεγχος PISMA: φεύγεις με σκορ και ευρώ στο χαρτί."
    ctaText="Κλείσε τον Έλεγχο"
    ctaHref="/elegxos/"
    note={`${ELEGXOS.price} · ${ELEGXOS.minutes} λεπτά · χωρίς δέσμευση`}
  />
</Base>

<style>
  /* Κάρτες σεναρίων */
  .case { display: flex; flex-direction: column; }
  .case-top {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
  }
  .case-top .tag { margin-top: 4px; text-align: right; flex: none; max-width: 55%; white-space: normal; }
  .case h3 { max-width: 26ch; }

  .case-metric-label {
    margin-top: 14px;
    font-size: .8rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
    color: var(--muted);
  }
  .case-nums {
    display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap;
    margin-top: 4px; margin-bottom: 16px;
  }
  .case-nums .strike { font-size: 1.05rem; }
  .case-arrow { color: var(--orange); font-weight: 700; font-size: 1.2rem; }
  .after-num { font-size: clamp(2.1rem, 4vw, 2.7rem); line-height: 1; }

  .case-setup {
    margin-top: auto; padding-top: 14px;
    border-top: 1px dashed var(--line);
    font-size: .92rem;
  }
  .case .card-arrow { margin-top: auto; padding-top: 14px; }

  /* Ζωντανή κάρτα — ελαφρώς ξεχωριστή */
  .case--live { border: 1.5px solid var(--ok); }
  .case--live .icon-chip { background: var(--ok-soft); color: var(--ok); }

  /* Πλαίσιο μελλοντικών μαρτυριών */
  .promise {
    max-width: 560px;
    border: 2px dashed var(--line);
    border-radius: var(--r);
    padding: clamp(22px, 3vw, 30px);
    background: transparent;
  }
  .promise h3 { margin-bottom: 8px; }
  .promise p { font-size: .97rem; color: var(--muted); }
</style>
