<script define:vars={{ tabs }}>
  const root = document.getElementById('flows');
  const btns = [...root.querySelectorAll('.flow-tab')];
  const slots = {
    trigger: root.querySelector('[data-slot="trigger"]'),
    engine: root.querySelector('[data-slot="engine"]'),
    out1: root.querySelector('[data-slot="out1"]'),
    out2: root.querySelector('[data-slot="out2"]'),
  };
  btns.forEach((b) => {
    b.addEventListener('click', () => {
      const t = tabs[Number(b.dataset.idx)];
      btns.forEach((x) => {
        x.classList.toggle('is-active', x === b);
        x.setAttribute('aria-selected', String(x === b));
      });
      for (const k of ['trigger', 'engine', 'out1', 'out2']) slots[k].textContent = t[k];
    });
  });
</script>

