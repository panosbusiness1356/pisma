---
import Base from '../layouts/Base.astro';
import { SITE, ELEGXOS, eur } from '../config';
import { PRESETS } from '../data/pricing';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE.name,
  slogan: SITE.tagline,
  email: SITE.email,
  telephone: SITE.phone,
  url: SITE.url,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Γλυφάδα',
    addressRegion: 'Αττική',
    addressCountry: 'GR',
  },
  areaServed: 'Νότια προάστια Αθήνας',
  founder: { '@type': 'Person', name: 'Πάνος' },
  description:
    'Ψηφιακή παρουσία και αυτοματοποίηση διαδικασιών για ελληνικές μικρομεσαίες επιχειρήσεις.',
};

const steps = [
  { t: 'Αξιολόγηση', d: `${ELEGXOS.minutes} λεπτά, χωρίς χρέωση. Καταγράφουμε τι χάνετε σε πελάτες και ώρες.` },
  { t: 'Πρόταση', d: `Γραπτή, εντός ${ELEGXOS.reportHours} ωρών, με σταθερή τιμή.` },
  { t: 'Υλοποίηση', d: 'Σε 2–4 εβδομάδες, στα εργαλεία που ήδη χρησιμοποιείτε.' },
  { t: 'Υποστήριξη', d: 'Μηνιαία αναφορά αποτελεσμάτων σε ώρες και ευρώ.' },
];


const plans = PRESETS;
const minSetup = Math.min(...PRESETS.map((p) => p.bundleOnce));
---

<Base
  title="PISMA — Ψηφιακή παρουσία & αυτοματοποίηση για μικρομεσαίες επιχειρήσεις | Γλυφάδα"
  description="Η PISMA σχεδιάζει την παρουσία της επιχείρησής σας σε ιστοσελίδα, Google και εφαρμογές AI, και αυτοματοποιεί τιμολόγηση, προσφορές και εισπράξεις. Σταθερές τιμές, μετρήσιμα αποτελέσματα."
  schema={schema}
>
  <!-- 1. Hero -->
  <section
    class="hero"
    aria-labelledby="hero-title"
    data-mascot-stop
    data-mascot-side="right"
    data-mascot-anchor="#hero-title"
    data-mascot-say="Καλώς ήρθατε στην PISMA. Συνεχίστε προς τα κάτω — θα σας δείξω τα βασικά."
  >
    <div class="beams" aria-hidden="true">
      <span class="beam beam--a"></span>
      <span class="beam beam--b"></span>
      <span class="beam beam--c"></span>
    </div>

    <div class="container hero-inner">
      <p class="hero-kicker blur-in" style="--d:.16s">Ψηφιακή παρουσία & αυτοματοποίηση</p>

      <h1 id="hero-title" class="blur-in" style="--d:.22s">
        Η επιχείρησή σας, ορατή στους πελάτες.<br />
        Η λειτουργία της, <span class="hero-hl">χωρίς χαμένες ώρες<svg class="hl-stroke" viewBox="0 0 320 30" preserveAspectRatio="none" aria-hidden="true"><defs><linearGradient id="hlGrad" x1="0" y1="0" x2="1" y2="0"><stop offset="0" stop-color="#FF8A50" /><stop offset="1" stop-color="#D63E1B" /></linearGradient></defs><path d="M6 15 C 60 9, 130 21, 200 14 C 245 10, 285 12, 314 13 C 260 18, 200 22, 120 21 C 90 20.5, 72 19, 58 18" fill="none" stroke="url(#hlGrad)" stroke-width="7.5" stroke-linecap="round" stroke-linejoin="round" opacity=".95" /></svg></span>.
      </h1>
      <script is:inline>
        // Κρύβει την υπογράμμιση πριν το πρώτο paint — θα τη «ζωγραφίσει» ο Ντοτ.
        (function () {
          var p = document.querySelector('.hl-stroke path');
          if (p && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
            var L = p.getTotalLength();
            p.style.strokeDasharray = String(L);
            p.style.strokeDashoffset = String(L);
          }
        })();
      </script>
      <p class="sub blur-in" style="--d:.34s">
        Η PISMA σχεδιάζει και υλοποιεί την παρουσία της επιχείρησής σας σε ιστοσελίδα,
        Google και εφαρμογές AI, και αυτοματοποιεί τις καθημερινές διαδικασίες —
        τιμολόγηση, προσφορές, εισπράξεις. <span class="sub-more">Με προκαθορισμένο κόστος
        και μετρήσιμο αποτέλεσμα.</span>
      </p>

      <div class="hero-ctas blur-in" style="--d:.46s">
        <span class="btn-frame">
          <a class="btn btn--orange" href="/tablo/">Μέτρησε την επιχείρησή σου — 2′</a>
        </span>
        <a class="btn btn--ghost" href="/elegxos/">Δωρεάν αξιολόγηση 45′</a>
      </div>
      <p class="btn-note blur-in" style="--d:.54s">Χωρίς email · χωρίς δέσμευση · το σκορ βγαίνει αμέσως</p>
    </div>

    <!-- Mockup Ταμπλό -->
    <div class="hero-screen blur-in" style="--d:.62s" aria-hidden="true">
      <div class="hero-screen-fade"></div>
      <div class="screen-frame">
        <div class="screen">
          <div class="screen-head">
            <span class="win-dots"><i></i><i></i><i></i></span>
            <span class="screen-title">Ενδεικτική αξιολόγηση — PISMA</span>
            <span class="tag tag--demo">Δείγμα</span>
          </div>
          <div class="screen-body">
            <div class="screen-rings">
              <div class="ring-box">
                <svg viewBox="0 0 120 120">
                  <circle class="ring-bg" cx="60" cy="60" r="52" />
                  <circle class="ring-val ring-val--low" cx="60" cy="60" r="52" />
                </svg>
                <span class="ring-num num">34</span>
                <span class="ring-label">Ορατότητα</span>
              </div>
              <div class="ring-box">
                <svg viewBox="0 0 120 120">
                  <circle class="ring-bg" cx="60" cy="60" r="52" />
                  <circle class="ring-val ring-val--mid" cx="60" cy="60" r="52" />
                </svg>
                <span class="ring-num num">57</span>
                <span class="ring-label">Αυτοματοποίηση</span>
              </div>
            </div>
            <div class="screen-stats">
              <div class="sstat">
                <span class="sstat-label">Ώρες διοικητικής εργασίας / μήνα</span>
                <span class="sstat-val num">22</span>
                <span class="sstat-bar"><i style="width:73%"></i></span>
              </div>
              <div class="sstat">
                <span class="sstat-label">Μέσος χρόνος είσπραξης</span>
                <span class="sstat-val num">47 ημέρες</span>
                <span class="sstat-bar"><i style="width:62%"></i></span>
              </div>
              <div class="sstat">
                <span class="sstat-label">Κόστος χειροκίνητης εργασίας</span>
                <span class="sstat-val num">330€ / μήνα</span>
                <span class="sstat-bar"><i style="width:84%"></i></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Υπηρεσίες -->
  <section
    class="section"
    aria-labelledby="svc-title"
    data-mascot-stop
    data-mascot-side="left"
    data-mascot-say="Δύο υπηρεσίες: προβολή που φέρνει πελάτες, και διαδικασίες που τρέχουν αυτόματα."
  >
    <div class="container">
      <div class="sec-head">
        <p class="kicker">Υπηρεσίες</p>
        <h2 id="svc-title">Τι αναλαμβάνουμε</h2>
      </div>
      <div class="grid-2">
        <article class="card svc reveal">
          <span class="icon-chip">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="10.5" cy="10.5" r="6.5" /><path d="M15.5 15.5 21 21" />
            </svg>
          </span>
          <h3>Ψηφιακή προβολή</h3>
          <ul class="svc-list">
            <li>Ιστοσελίδα σχεδιασμένη να μετατρέπει επισκέπτες σε πελάτες</li>
            <li>Κατάταξη στην αναζήτηση και τους Χάρτες Google της περιοχής σας</li>
            <li>Παρουσία στις απαντήσεις εργαλείων AI, όπως το ChatGPT</li>
          </ul>
          <a class="card-arrow" href="/se-vriskoun/">Αναλυτικά →</a>
        </article>
        <article class="card svc svc--blue reveal">
          <span class="icon-chip icon-chip--blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="3.2" /><path d="M12 2.5v3M12 18.5v3M2.5 12h3M18.5 12h3M5.3 5.3l2.1 2.1M16.6 16.6l2.1 2.1M18.7 5.3l-2.1 2.1M7.4 16.6l-2.1 2.1" />
            </svg>
          </span>
          <h3>Αυτοματοποίηση διαδικασιών</h3>
          <ul class="svc-list">
            <li>Αυτόματη έκδοση και αποστολή παραστατικών, σε συμφωνία με το myDATA</li>
            <li>Συστηματική παρακολούθηση και υπενθύμιση εισπράξεων</li>
            <li>Τυποποιημένες προσφορές, έτοιμες σε λίγα λεπτά</li>
          </ul>
          <a class="card-arrow" href="/doulevei-mono-tou/">Αναλυτικά →</a>
        </article>
      </div>
    </div>
  </section>

  <!-- 3. Μεθοδολογία -->
  <section
    class="section section--tight"
    aria-labelledby="method-title"
    data-mascot-stop
    data-mascot-side="right"
    data-mascot-say="Κάθε συνεργασία ξεκινά με δωρεάν αξιολόγηση 45 λεπτών — παραλαμβάνετε τα ευρήματα γραπτώς."
  >
    <div class="container">
      <div class="sec-head">
        <p class="kicker kicker--yellow">Μεθοδολογία</p>
        <h2 id="method-title">Πώς δουλεύουμε — σε 4 βήματα</h2>
      </div>
      <ol class="steps">
        {steps.map((s, i) => (
          <li class="step reveal">
            <span class="step-num num">{i + 1}</span>
            <h3>{s.t}</h3>
            <p>{s.d}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- 4. Ηλεκτρονική τιμολόγηση 2026: ΠΡΟΣΩΡΙΝΑ ΕΚΤΟΣ — φυλάσσεται στο
       components/Einvoice2026.astro, επαναφορά με <Einvoice2026 /> εδώ. -->

  <!-- 6. Τιμολόγηση -->
  <section
    class="section section--tight"
    aria-labelledby="pricing-title"
    data-mascot-stop
    data-mascot-side="left"
    data-mascot-say={`Όλες οι τιμές δημοσιεύονται αναλυτικά — πακέτα από ${eur(minSetup)} εφάπαξ.`}
  >
    <div class="container">
      <div class="sec-head">
        <p class="kicker kicker--blue">Τιμολόγηση</p>
        <h2 id="pricing-title">Οι τιμές μας, δημόσιες — φτιάξτε το πακέτο σας</h2>
        <p>Γνωρίζετε το κόστος πριν από την πρώτη επικοινωνία.</p>
      </div>
      <div class="grid-3">
        {plans.map((p) => (
          <article class="card plan-mini reveal">
            <h3>{p.name}</h3>
            <p class="plan-mini-setup"><span class="num">{eur(p.bundleOnce)}</span> εφάπαξ</p>
            <p class="plan-mini-monthly">
              {p.bundleMonthly > 0
                ? <>+ <span class="num">{eur(p.bundleMonthly)}</span> / μήνα</>
                : <>χωρίς μηνιαίο κόστος</>}
            </p>
          </article>
        ))}
      </div>
      <div class="cases-cta">
        <a class="btn btn--navy" href="/times/">Δείτε αναλυτικά τις τιμές →</a>
      </div>
    </div>
  </section>

  <!-- 7. Η εταιρία -->
  <section class="section section--tight" aria-labelledby="who-title">
    <div class="container">
      <div class="card who reveal">
        <div>
          <p class="kicker">Η εταιρία</p>
          <h2 id="who-title">Άμεση συνεργασία, χωρίς ενδιάμεσους</h2>
          <p>
            Συνεργάζεστε απευθείας με τον υπεύθυνο σχεδιασμού και υλοποίησης — χωρίς
            τμήμα πωλήσεων. Ό,τι υλοποιείται, ανήκει στην επιχείρησή σας.
          </p>
          <p class="who-sig">{SITE.founder} · {SITE.area}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. Τελικό κάλεσμα -->
  <section
    class="section final-cta"
    aria-labelledby="final-title"
    data-mascot-stop
    data-mascot-side="right"
    data-mascot-say="Ξεκινήστε με τη δωρεάν αξιολόγηση — 45 λεπτά, χωρίς δέσμευση."
  >
    <div class="container">
      <h2 id="final-title">Ξεκινήστε με μια δωρεάν<br /><span class="grad-text">αξιολόγηση 45 λεπτών</span></h2>
      <p>
        Καταγράφουμε τι χάνετε σε πελάτες και χρόνο — παραλαμβάνετε τα ευρήματα γραπτώς.
      </p>
      <a class="btn btn--orange" href="/elegxos/">Κλείστε τη δωρεάν αξιολόγηση</a>
      <p class="btn-note">45 λεπτά · χωρίς χρέωση · χωρίς δέσμευση</p>
    </div>
  </section>
</Base>

<style>
  /* ---------- Hero ---------- */
  .hero { padding-top: clamp(48px, 7vw, 100px); position: relative; overflow: clip; }
  .hero-inner { text-align: center; position: relative; z-index: 1; }
  .hero-kicker {
    margin-bottom: clamp(18px, 3vw, 28px);
    font-size: .76rem; font-weight: 700;
    letter-spacing: .14em; text-transform: uppercase;
    color: var(--orange-text);
    text-wrap: balance;
  }
  .hero h1 { max-width: 24ch; margin-inline: auto; font-size: clamp(2rem, 5vw, 3.9rem); }
  .hero-hl { position: relative; white-space: nowrap; }
  .hl-stroke {
    position: absolute; left: -.06em; bottom: -.16em;
    width: calc(100% + .12em); height: .34em;
    overflow: visible; pointer-events: none;
  }
  .hero .sub { margin: 24px auto 0; font-size: 1.1rem; color: var(--muted); max-width: 62ch; }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-top: 36px; }
  .hero .btn-note { margin-top: 14px; }
  .btn-frame {
    display: inline-flex; padding: 3px; border-radius: 14px;
    background: rgba(255, 255, 255, .08); border: 1px solid var(--line);
  }

  /* Announcement pill */
  .announce {
    display: inline-flex; align-items: center; gap: 12px;
    background: var(--card-2); border: 1px solid var(--line-strong);
    border-radius: 999px; padding: 5px 5px 5px 16px;
    font-size: .85rem; color: var(--ink); text-decoration: none;
    box-shadow: var(--shadow);
    transition: border-color .25s ease, background-color .25s ease;
    margin-bottom: clamp(22px, 3.5vw, 36px);
    max-width: min(94%, 560px);
  }
  .announce-text {
    min-width: 0; overflow: hidden;
    text-overflow: ellipsis; white-space: nowrap;
  }
  .announce:hover { border-color: rgba(255, 255, 255, .28); background: var(--bg-soft); }
  .announce-sep { width: 1px; height: 16px; background: var(--line-strong); flex: none; }
  .announce-arrow {
    width: 26px; height: 26px; border-radius: 50%; overflow: hidden; flex: none;
    background: var(--bg); display: block;
  }
  .announce-arrow-track {
    display: flex; width: 52px; height: 26px;
    transform: translateX(-50%);
    transition: transform .5s ease;
  }
  .announce:hover .announce-arrow-track { transform: translateX(0); }
  .announce-arrow-track svg { width: 12px; height: 26px; margin-inline: auto; color: var(--orange-text); flex: none; padding-block: 7px; box-sizing: content-box; padding-inline: 7px; }

  /* Beams */
  .beams { position: absolute; inset: 0; pointer-events: none; opacity: .5; display: none; }
  @media (min-width: 1024px) { .beams { display: block; } }
  .beam { position: absolute; left: 0; top: 0; rotate: -45deg; border-radius: 999px; }
  .beam--a {
    width: 35rem; height: 80rem; translate: 0 -350px;
    background: radial-gradient(68.54% 68.72% at 55.02% 31.46%, rgba(255, 235, 225, .08) 0, rgba(180, 160, 150, .02) 50%, transparent 80%);
  }
  .beam--b {
    width: 14rem; height: 80rem; translate: 5% -50%;
    background: radial-gradient(50% 50% at 50% 50%, rgba(255, 235, 225, .06) 0, rgba(180, 160, 150, .02) 80%, transparent 100%);
  }
  .beam--c {
    width: 14rem; height: 80rem; translate: 0 -350px;
    background: radial-gradient(50% 50% at 50% 50%, rgba(255, 235, 225, .04) 0, rgba(180, 160, 150, .02) 80%, transparent 100%);
  }

  /* Mockup */
  .hero-screen { position: relative; margin-top: clamp(36px, 6vw, 72px); padding-inline: clamp(10px, 3vw, 36px); }
  .hero-screen-fade {
    position: absolute; inset: 0; z-index: 2; pointer-events: none;
    background: linear-gradient(to bottom, transparent 35%, var(--bg) 100%);
  }
  .screen-frame {
    max-width: 980px; margin-inline: auto;
    background: rgba(255, 255, 255, .05);
    border: 1px solid var(--line-strong);
    border-radius: 22px; padding: 5px;
    box-shadow: 0 30px 80px rgba(0, 0, 0, .5);
  }
  .screen { background: var(--bg-soft); border-radius: 17px; overflow: hidden; border: 1px solid var(--line); }
  .screen-head {
    display: flex; align-items: center; gap: 12px;
    padding: 12px 18px; border-bottom: 1px solid var(--line);
    background: var(--card);
  }
  .win-dots { display: inline-flex; gap: 6px; }
  .win-dots i { width: 10px; height: 10px; border-radius: 50%; background: var(--line-strong); }
  .screen-title { font-size: .85rem; font-weight: 700; color: var(--navy); margin-right: auto; }
  .screen-body {
    display: grid; gap: clamp(20px, 4vw, 48px);
    grid-template-columns: auto 1fr; align-items: center;
    padding: clamp(20px, 3.5vw, 40px);
  }
  .screen-rings { display: flex; gap: clamp(16px, 3vw, 32px); }
  .ring-box { position: relative; width: clamp(96px, 12vw, 136px); text-align: center; }
  .ring-box svg { transform: rotate(-90deg); }
  .ring-bg, .ring-val { fill: none; stroke-width: 10; }
  .ring-bg { stroke: rgba(255, 255, 255, .1); }
  .ring-val { stroke-linecap: round; stroke-dasharray: 326.7; }
  .ring-val--low { stroke: var(--red); stroke-dashoffset: calc(326.7 * (1 - .34)); }
  .ring-val--mid { stroke: var(--orange); stroke-dashoffset: calc(326.7 * (1 - .57)); }
  .ring-num {
    position: absolute; top: 33%; left: 0; right: 0;
    font-size: 1.5rem; font-weight: 700; color: var(--navy);
  }
  .ring-label { display: block; margin-top: 8px; font-size: .8rem; color: var(--muted); }
  .screen-stats { display: grid; gap: 16px; min-width: 0; }
  .sstat { display: grid; grid-template-columns: 1fr auto; gap: 4px 12px; align-items: baseline; }
  .sstat-label { font-size: .85rem; color: var(--muted); }
  .sstat-val { font-weight: 700; color: var(--navy); font-size: .95rem; }
  .sstat-bar { grid-column: 1 / -1; height: 6px; border-radius: 999px; background: rgba(255, 255, 255, .08); overflow: hidden; }
  .sstat-bar i { display: block; height: 100%; border-radius: 999px; background: var(--grad); }
  @media (max-width: 680px) {
    .screen-body { grid-template-columns: 1fr; justify-items: center; }
    .screen-stats { width: 100%; }
  }

  /* ---------- Υπηρεσίες ---------- */
  .svc { display: flex; flex-direction: column; }
  .svc-list { list-style: none; padding: 0; margin: 4px 0 8px; display: grid; gap: 10px; }
  .svc-list li {
    position: relative; padding-left: 22px;
    font-size: .97rem; color: var(--muted); line-height: 1.55;
  }
  .svc-list li::before {
    content: ''; position: absolute; left: 2px; top: .52em;
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--orange);
  }
  .svc .card-arrow { margin-top: auto; padding-top: 12px; }
  .svc--blue .svc-list li::before { background: var(--blue); }
  .svc--blue .card-arrow { color: var(--blue-text); }

  /* Μεθοδολογία: κάθε στάδιο με τη δική του απόχρωση (μουντοί, σοβαροί τόνοι) */
  .steps li:nth-child(2) .step-num { background: var(--blue); }
  .steps li:nth-child(3) .step-num { background: var(--yellow); color: #2E2107; }
  .steps li:nth-child(4) .step-num { background: var(--ok); color: #0E2B1B; }

  /* ---------- Πορτοκαλί panel ---------- */
  .einv {
    border-radius: calc(var(--r) + 6px); overflow: hidden;
    background:
      radial-gradient(120% 160% at 90% 110%, rgba(255, 210, 150, .35), transparent 55%),
      linear-gradient(115deg, #D63E1B 0%, #EE4F27 45%, #FF8A3D 100%);
    padding: clamp(28px, 5vw, 56px);
    display: grid; gap: clamp(26px, 5vw, 56px);
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    align-items: center;
    box-shadow: var(--shadow), var(--glow-orange);
  }
  .einv h2, .einv p, .einv li { color: #fff; }
  .einv p { opacity: .93; margin-top: 12px; max-width: 56ch; }
  .einv-checks { list-style: none; padding: 0; margin: 20px 0 26px; display: grid; gap: 10px; font-weight: 600; font-size: .97rem; }
  .einv-checks span { margin-right: 8px; font-weight: 800; }
  .btn--light { background: #fff; color: #C13A20; }
