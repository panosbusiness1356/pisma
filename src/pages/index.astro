---
import Base from '../layouts/Base.astro';
import { SITE, EINVOICE, ELEGXOS, eur } from '../config';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE.name,
  slogan: SITE.tagline,
  email: SITE.email,
  telephone: SITE.phone,
  url: SITE.url,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Γλυφάδα',
    addressRegion: 'Αττική',
    addressCountry: 'GR',
  },
  areaServed: 'Νότια προάστια Αθήνας',
  founder: { '@type': 'Person', name: 'Πάνος' },
  description:
    'Ορατότητα σε Google και AI, και αυτοματισμοί γραφείου για ελληνικές μικρομεσαίες επιχειρήσεις.',
};

/** Tabs: τι στήνει η PISMA, ένα σενάριο ροής ανά tab. */
const tabs = [
  {
    key: 'Ορατότητα',
    desc: 'Site, Google και ChatGPT: όταν κάποιος ψάχνει ό,τι κάνεις, να βγαίνεις εσύ.',
    trigger: 'Πελάτης ψάχνει στο Google ή ρωτά το ChatGPT',
    engine: 'Παρουσία στημένη από την PISMA',
    out1: 'Βρίσκει εσένα — όχι τον ανταγωνιστή',
    out2: 'Κλείνει ραντεβού από το site',
  },
  {
    key: 'Τιμολόγηση',
    desc: 'Τα παραστατικά κόβονται και φεύγουν μόνα τους — έτοιμα και για myDATA.',
    trigger: 'Ολοκληρώνεται μια δουλειά',
    engine: 'Αυτόματη έκδοση τιμολογίου',
    out1: 'Στέλνεται στον πελάτη',
    out2: 'Καταχωρείται στο myDATA',
  },
  {
    key: 'Εισπράξεις',
    desc: 'Υπενθυμίσεις πληρωμής σε 3 βήματα — ευγενικές στην αρχή, σταθερές μετά.',
    trigger: 'Τιμολόγιο μένει απλήρωτο 30 μέρες',
    engine: 'Υπενθύμιση σε 3 βήματα',
    out1: 'Ο πελάτης πληρώνει',
    out2: 'Εσύ ειδοποιείσαι — χωρίς τηλέφωνα',
  },
  {
    key: 'Προσφορές',
    desc: 'Από το αίτημα στην έτοιμη προσφορά σε λεπτά, όχι σε μέρες.',
    trigger: 'Νέο αίτημα από πελάτη',
    engine: 'Πρότυπο προσφοράς PISMA',
    out1: 'PDF προσφορά στον πελάτη',
    out2: 'Follow-up σε 3 μέρες, μόνο του',
  },
  {
    key: 'Εσύ',
    desc: 'Μία αναφορά τον μήνα: ώρες που γλίτωσες, ευρώ που κέρδισες.',
    trigger: 'Τέλος του μήνα',
    engine: 'Απόδειξη Αξίας PISMA',
    out1: 'Ώρες που γλίτωσες',
    out2: 'Ευρώ που κέρδισες',
  },
] as const;

/** Πλέγμα «δένει με τα εργαλεία σου» — γενικά εικονίδια, όχι λογότυπα. */
const integrations = [
  { label: 'Email', svg: '<path d="M4 6h16a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1Z"/><path d="m3.5 7 8.5 6 8.5-6"/>' },
  { label: 'Υπολογιστικά φύλλα', svg: '<rect x="4" y="4" width="16" height="16" rx="2"/><path d="M4 10h16M10 4v16"/>' },
  { label: 'Ημερολόγιο', svg: '<rect x="4" y="5" width="16" height="15" rx="2"/><path d="M8 3v4M16 3v4M4 10h16"/>' },
  { label: 'Τηλέφωνο', svg: '<path d="M6 3h4l1.5 5-2.5 2a13 13 0 0 0 5 5l2-2.5 5 1.5v4a2 2 0 0 1-2 2A17 17 0 0 1 4 5a2 2 0 0 1 2-2Z"/>' },
  { label: 'Μηνύματα', svg: '<path d="M21 12a8 8 0 0 1-8 8H4l2-3a8 8 0 1 1 15-5Z"/><path d="M9 11h6M9 14h4"/>' },
  { label: 'E-shop', svg: '<circle cx="9" cy="20" r="1.4"/><circle cx="17" cy="20" r="1.4"/><path d="M3 4h3l2.5 11H18l2.5-8H7"/>' },
  { label: 'Τιμολόγια', svg: '<path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8Z"/><path d="M14 3v5h5M9 13h6M9 17h4"/>' },
  { label: 'Τράπεζα', svg: '<path d="M3 9.5 12 4l9 5.5"/><path d="M5 10v7M9.5 10v7M14.5 10v7M19 10v7M3 20h18"/>' },
  { label: 'Χάρτες', svg: '<path d="M12 21s-6.5-5.4-6.5-10a6.5 6.5 0 0 1 13 0c0 4.6-6.5 10-6.5 10Z"/><circle cx="12" cy="11" r="2.4"/>' },
  { label: 'Κριτικές', svg: '<path d="m12 3 2.7 5.7 6.3.8-4.6 4.3 1.2 6.2L12 17l-5.6 3 1.2-6.2L3 9.5l6.3-.8Z"/>' },
  { label: 'Κοινωνικά δίκτυα', svg: '<rect x="4" y="4" width="16" height="16" rx="4.5"/><circle cx="12" cy="12" r="3.6"/><circle cx="17" cy="7" r="1"/>' },
  { label: 'Κάρτες / POS', svg: '<rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10.5h18M7 15.5h4"/>' },
  { label: 'Αποστολές / courier', svg: '<path d="M3 7h11v10H3zM14 10h4l3 3v4h-7"/><circle cx="7" cy="18.5" r="1.6"/><circle cx="17" cy="18.5" r="1.6"/>' },
  { label: 'Αρχεία', svg: '<path d="M4 7a2 2 0 0 1 2-2h4l2 2.5h6A2 2 0 0 1 20 9.5V17a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2Z"/>' },
  { label: 'Ειδοποιήσεις', svg: '<path d="M18 15v-4.5a6 6 0 1 0-12 0V15l-1.8 2.6h15.6Z"/><path d="M10.3 20.4a2 2 0 0 0 3.4 0"/>' },
  { label: 'Αναφορές', svg: '<path d="M4 20V4"/><path d="M4 20h16"/><path d="M8 16v-5M12 16V8M16 16v-8"/>' },
  { label: 'Cloud', svg: '<path d="M7 18a4.5 4.5 0 1 1 .8-8.9A5.5 5.5 0 0 1 18.5 10 4 4 0 0 1 18 18Z"/>' },
  { label: 'AI', svg: '<rect x="5" y="7" width="14" height="12" rx="3"/><circle cx="9.5" cy="12.5" r="1.2"/><circle cx="14.5" cy="12.5" r="1.2"/><path d="M12 7V3.5M12 3.5h3"/>' },
] as const;

const fastChecks = [
  { t: 'Μέτρηση πριν από κάθε αλλαγή', d: 'Πρώτα το σκορ και τα ευρώ στο χαρτί — μετά η δουλειά.' },
  { t: 'Γραπτή πρόταση, σταθερή τιμή', d: `Σε ${ELEGXOS.reportHours} ώρες μετά τον Έλεγχο. Χωρίς εκπλήξεις.` },
  { t: 'Στήσιμο χωρίς διακοπές', d: 'Σε 2–4 εβδομάδες, χωρίς να αλλάξεις πρόγραμμα ή εργαλεία.' },
  { t: 'Απόδειξη Αξίας κάθε μήνα', d: 'Ώρες και ευρώ, μετρημένα — όχι εντυπώσεις.' },
  { t: 'Όλα αναστρέψιμα', d: 'Ό,τι στήνεται, τεκμηριώνεται. Σταματάς όποτε θες.' },
  { t: 'Ένας άνθρωπος, όχι τμήμα', d: 'Μιλάς με αυτόν που στήνει το σύστημα — τον Πάνο.' },
] as const;

const trustRows = [
  { t: 'Ασφάλεια και δεδομένα', d: 'Δικοί σου λογαριασμοί, δικά σου δεδομένα. Έχεις πρόσβαση σε όλα, ανά πάσα στιγμή.' },
  { t: 'Διαφάνεια', d: 'Κάθε αυτοματισμός είναι τεκμηριωμένος. Ξέρεις ακριβώς τι τρέχει και πότε.' },
  { t: 'Συντήρηση', d: 'Παρακολούθηση κάθε μήνα, με γραπτή αναφορά. Αν κάτι σπάσει, το μαθαίνεις από εμάς — όχι από πελάτη.' },
  { t: 'Ιδιοκτησία', d: 'Ό,τι στήνεται είναι δικό σου. Φεύγεις όποτε θες, με όλα στα χέρια σου.' },
] as const;

const demoCases = [
  {
    title: 'Εμπορική εταιρεία — περίπου 400 παραστατικά τον μήνα',
    metric: 'Καταχώρηση εισερχομένων',
    before: '22 ώρες/μήνα',
    after: '3 ώρες/μήνα',
    setup: 'Αυτόματη ανάγνωση παραστατικών από το email και καταχώρηση στο σύστημα — ο άνθρωπος μόνο εγκρίνει.',
  },
  {
    title: 'Τεχνική εταιρεία — έργα με πίστωση',
    metric: 'Μέση είσπραξη',
    before: '47 μέρες',
    after: '31 μέρες',
    setup: 'Αυτόματες υπενθυμίσεις είσπραξης σε 3 βήματα — ευγενικές στην αρχή, σταθερές μετά.',
  },
] as const;
---

<Base
  title="PISMA — Να σε βρίσκουν πελάτες. Να δουλεύει μόνο του. | Γλυφάδα"
  description="Μετράμε τι χάνει η επιχείρησή σου σε πελάτες και ώρες — και το διορθώνουμε. SEO, ορατότητα σε AI και αυτοματισμοί γραφείου για ελληνικές ΜμΕ."
  schema={schema}
>
  <!-- 1. Hero -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="beams" aria-hidden="true">
      <span class="beam beam--a"></span>
      <span class="beam beam--b"></span>
      <span class="beam beam--c"></span>
    </div>

    <div class="container hero-inner">
      <a class="announce blur-in" style="--d:.1s" href="/timologisi-2026/">
        <span class="announce-text">Νέο: Ηλεκτρονική τιμολόγηση 2026 — δες τι αλλάζει</span>
        <span class="announce-sep" aria-hidden="true"></span>
        <span class="announce-arrow" aria-hidden="true">
          <span class="announce-arrow-track">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </span>
        </span>
      </a>

      <h1 id="hero-title" class="blur-in" style="--d:.22s">
        Να σε βρίσκουν πελάτες.<br />
        Να δουλεύει <span class="hero-hl">μόνο του</span>.
      </h1>
      <p class="sub blur-in" style="--d:.34s">
        Μετράμε τι χάνεις — σε πελάτες και σε ώρες — και το διορθώνουμε.
        Με νούμερα, όχι λόγια. Για ελληνικές μικρομεσαίες επιχειρήσεις.
      </p>

      <div class="hero-ctas blur-in" style="--d:.46s">
        <span class="btn-frame">
          <a class="btn btn--orange" href="/tablo/">Μέτρησε την επιχείρησή σου</a>
        </span>
        <a class="btn btn--ghost" href="/elegxos/">Κλείσε τον Έλεγχο</a>
      </div>
      <p class="btn-note blur-in" style="--d:.54s">2 λεπτά · δωρεάν · χωρίς email — το σκορ βγαίνει μπροστά σου</p>
    </div>

    <!-- Mockup Ταμπλό -->
    <div class="hero-screen blur-in" style="--d:.62s" aria-hidden="true">
      <div class="hero-screen-fade"></div>
      <div
        class="screen-frame"
        data-mascot-stop
        data-mascot-pose="sit"
        data-mascot-side="right"
        data-mascot-say="Γεια! Είμαι ο Οκτώ. Κάνε scroll — σε ξεναγώ εγώ!"
        <div class="screen">
          <div class="screen-head">
            <span class="win-dots"><i></i><i></i><i></i></span>
            <span class="screen-title">Το Ταμπλό — PISMA</span>
            <span class="tag tag--demo">Δείγμα</span>
          </div>
          <div class="screen-body">
            <div class="screen-rings">
              <div class="ring-box">
                <svg viewBox="0 0 120 120">
                  <circle class="ring-bg" cx="60" cy="60" r="52" />
                  <circle class="ring-val ring-val--low" cx="60" cy="60" r="52" />
                </svg>
                <span class="ring-num num">34</span>
                <span class="ring-label">Ορατότητα</span>
              </div>
              <div class="ring-box">
                <svg viewBox="0 0 120 120">
                  <circle class="ring-bg" cx="60" cy="60" r="52" />
                  <circle class="ring-val ring-val--mid" cx="60" cy="60" r="52" />
                </svg>
                <span class="ring-num num">57</span>
                <span class="ring-label">Αυτοματισμός</span>
              </div>
            </div>
            <div class="screen-stats">
              <div class="sstat">
                <span class="sstat-label">Ώρες σε admin / μήνα</span>
                <span class="sstat-val num">22</span>
                <span class="sstat-bar"><i style="width:73%"></i></span>
              </div>
              <div class="sstat">
                <span class="sstat-label">Μέση είσπραξη</span>
                <span class="sstat-val num">47 μέρες</span>
                <span class="sstat-bar"><i style="width:62%"></i></span>
              </div>
              <div class="sstat">
                <span class="sstat-label">Κόστος χειροκίνητης δουλειάς</span>
                <span class="sstat-val num">330€ / μήνα</span>
                <span class="sstat-bar"><i style="width:84%"></i></span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 1β. Cloud εργαλείων -->
  <section class="section--tight cloud" aria-label="Δουλεύουμε με τα εργαλεία σου">
    <div class="container cloud-wrap">
      <a class="cloud-link" href="/doulevei-mono-tou/">Δες πώς δένουν όλα μαζί
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6" /></svg>
      </a>
      <ul class="cloud-grid" aria-label="Ενδεικτικά εργαλεία">
        <li>Google</li><li>ChatGPT</li><li>Gmail</li><li>myDATA</li>
        <li>Viber</li><li>Sheets</li><li>E-shop</li><li>Maps</li>
      </ul>
    </div>
  </section>

  <!-- 2. Tabs + διάγραμμα ροής -->
  <section
    class="section section--tight"
    aria-labelledby="flows-title"
    data-mascot-stop
    data-mascot-side="left"
    data-mascot-say="Πάτα τις καρτέλες — όλα αυτά τα αναλαμβάνω εγώ."
  >
    <div class="container">
      <div class="flows card--navy" id="flows">
        <div class="flows-tabs" role="tablist" aria-label="Τι στήνουμε">
          <h2 id="flows-title" class="visually-hidden">Τι στήνουμε</h2>
          {tabs.map((t, i) => (
            <button
              class={`flow-tab${i === 0 ? ' is-active' : ''}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-idx={i}
              type="button"
            >
              <span class="flow-tab-t">{t.key}</span>
              <span class="flow-tab-d">{t.desc}</span>
            </button>
          ))}
        </div>

        <div class="flow-diagram" aria-live="polite">
          <div class="fnode fnode--trigger">
            <span class="fnode-label">Έναυσμα</span>
            <span class="fnode-text" data-slot="trigger">{tabs[0].trigger}</span>
          </div>
          <div class="fline" aria-hidden="true"></div>
          <div class="fnode fnode--engine">
            <span class="fnode-label">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13 2 4 14h6l-1 8 9-12h-6z" /></svg>
              PISMA
            </span>
            <span class="fnode-text" data-slot="engine">{tabs[0].engine}</span>
          </div>
          <div class="fline fline--split" aria-hidden="true"></div>
          <div class="fouts">
            <div class="fnode fnode--out">
              <span class="fnode-check" aria-hidden="true">✓</span>
              <span class="fnode-text" data-slot="out1">{tabs[0].out1}</span>
            </div>
            <div class="fnode fnode--out">
              <span class="fnode-check" aria-hidden="true">✓</span>
              <span class="fnode-text" data-slot="out2">{tabs[0].out2}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Social proof strip -->
  <section class="section--tight" aria-label="Στοιχεία αγοράς">
    <div class="container stats">
      <p class="chip reveal"><strong class="num">74%</strong> των ΜμΕ δεν βρίσκει προσωπικό — ΒΕΑ/KPMG</p>
      <p class="chip reveal"><strong class="num">40%</strong> του χρόνου του ιδιοκτήτη πάει σε admin</p>
      <p class="chip reveal"><strong class="num">{EINVOICE.deadlineShort}</strong> η προθεσμία ηλεκτρονικής τιμολόγησης</p>
    </div>
  </section>

  <!-- 4. Integrations -->
  <section
    class="section"
    aria-labelledby="integr-title"
    data-mascot-stop
    data-mascot-side="right"
    data-mascot-say="Δένω με τα εργαλεία που ήδη έχεις — δεν αλλάζεις τίποτα."
  >
    <div class="container">
      <div class="sec-head sec-head--center">
        <h2 id="integr-title">Δένει με τα εργαλεία<br />που <span class="grad-text">ήδη έχεις</span></h2>
        <p>Email, λογιστικά, ημερολόγιο, e-shop, courier — δεν αλλάζεις τίποτα. Τα ενώνουμε να δουλεύουν μαζί.</p>
      </div>
      <ul class="integr-grid reveal" aria-label="Κατηγορίες εργαλείων">
        {integrations.map((it) => (
          <li class="integr-tile" title={it.label}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={it.svg} />
            <span class="visually-hidden">{it.label}</span>
          </li>
        ))}
      </ul>
      <div class="integr-cta">
        <a class="btn btn--navy" href="/doulevei-mono-tou/">Δες πώς ενώνονται όλα →</a>
      </div>
    </div>
  </section>

  <!-- 5. Features: σύστημα που βλέπεις και ελέγχεις -->
  <section
    class="section"
    aria-labelledby="feat-title"
    data-mascot-stop
    data-mascot-side="left"
    data-mascot-say="Εδώ κάνεις κουμάντο εσύ — το τελευταίο «ναι» είναι πάντα δικό σου."
  >
    <div class="container">
      <div class="sec-head sec-head--center">
        <h2 id="feat-title">Σύστημα που βλέπεις<br />και ελέγχεις</h2>
        <p>Όχι «κάτι τρέχει από πίσω». Βλέπεις κάθε βήμα — και το τελευταίο «ναι» είναι πάντα δικό σου.</p>
      </div>

      <div class="grid-2">
        <article class="card reveal">
          <h3>Χωρίς μαύρα κουτιά</h3>
          <p>Κάθε αυτοματισμός είναι μια ροή που διαβάζεται: τι μπαίνει, τι γίνεται, τι βγαίνει.</p>
          <ul class="mini-flow" aria-label="Παράδειγμα ροής">
            <li><span class="ok">✓</span> Έρχεται παραστατικό στο email</li>
            <li><span class="ok">✓</span> Διαβάζεται και ελέγχεται</li>
            <li><span class="ok">✓</span> Καταχωρείται στο σύστημα</li>
            <li class="mini-flow-you"><span class="you">Εσύ</span> Εγκρίνεις με ένα κλικ</li>
          </ul>
        </article>

        <article class="card reveal">
          <h3>Ο άνθρωπος αποφασίζει</h3>
          <p>Όπου χρειάζεται κρίση — ποσά, εξαιρέσεις, νέοι πελάτες — η ροή σταματά και σε ρωτάει.</p>
          <div class="approve" aria-hidden="true">
            <p class="approve-q">Να σταλεί υπενθύμιση 2ου βήματος στον πελάτη Χ;</p>
            <div class="approve-btns">
              <span class="approve-yes">Ναι, στείλε</span>
              <span class="approve-no">Όχι, θα τον πάρω εγώ</span>
            </div>
          </div>
        </article>
      </div>

      <article class="card card--navy feat-wide reveal">
        <div>
          <h3>Μένει δικό σου</h3>
          <p>Δεν σε κλειδώνουμε πουθενά. Το σύστημα στήνεται στα δικά σου εργαλεία και μένει σε σένα.</p>
        </div>
        <ul class="feat-checks">
          <li><span class="ok">✓</span> Στο δικό σου email και τα δικά σου προγράμματα</li>
          <li><span class="ok">✓</span> Δικοί σου λογαριασμοί, δικά σου δεδομένα</li>
          <li><span class="ok">✓</span> Σταματάς όποτε θες — χωρίς δεσμεύσεις</li>
        </ul>
      </article>
    </div>
  </section>

  <!-- 6. Πορτοκαλί panel: Ηλεκτρονική τιμολόγηση 2026 -->
  <section
    class="section section--tight"
    aria-labelledby="einv-title"
    data-mascot-stop
    data-mascot-side="right"
